{% layout 'theme' %}

<div class="account-page__header">
  <div class="container">
    <h1>{{ 'customer.account.title' | t }}</h1>
    <p>Welcome back, {{ customer.first_name }}!</p>
  </div>
</div>

<div class="account-page">
  <div class="container">
    <div class="account-page__inner">

      <!-- Sidebar Nav -->
      <nav class="account-nav" aria-label="Account navigation">
        <a href="{{ routes.account_url }}" class="active">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
            <circle cx="12" cy="7" r="4"></circle>
          </svg>
          My Account
        </a>
        <a href="{{ routes.account_url }}/orders">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
            <line x1="3" y1="6" x2="21" y2="6"></line>
          </svg>
          {{ 'customer.account.orders' | t }}
        </a>
        <a href="{{ routes.account_addresses_url }}">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
            <circle cx="12" cy="10" r="3"></circle>
          </svg>
          Addresses
        </a>
        <a href="{{ routes.account_logout_url }}">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
            <polyline points="16 17 21 12 16 7"></polyline>
            <line x1="21" y1="12" x2="9" y2="12"></line>
          </svg>
          {{ 'customer.account.logout' | t }}
        </a>
      </nav>

      <!-- Main Content -->
      <div>
        <h2 style="font-family:'Oswald',sans-serif; font-size:1.35rem; color:var(--color-primary); margin-bottom:1.5rem;">
          {{ 'customer.account.orders' | t }}
        </h2>

        {% if customer.orders.size > 0 %}
          <div style="overflow-x:auto;">
            <table class="orders-table">
              <thead>
                <tr>
                  <th>Order</th>
                  <th>Date</th>
                  <th>Status</th>
                  <th>Items</th>
                  <th>Total</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                {% for order in customer.orders %}
                  <tr>
                    <td><strong>{{ order.name }}</strong></td>
                    <td>{{ order.created_at | date: "%b %d, %Y" }}</td>
                    <td>
                      <span class="order-status order-status--{{ order.fulfillment_status | replace: ' ', '-' | downcase }}">
                        {{ order.fulfillment_status | capitalize | replace: '_', ' ' }}
                      </span>
                    </td>
                    <td>{{ order.line_items.size }} item{% if order.line_items.size != 1 %}s{% endif %}</td>
                    <td>{{ order.total_price | money }}</td>
                    <td><a href="{{ order.customer_url }}" style="color:var(--color-secondary); font-size:0.85rem; font-weight:600;">View</a></td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        {% else %}
          <div style="padding:3rem; text-align:center; background:#f4f7fa; border-radius:8px; color:#888;">
            <p style="margin-bottom:1.25rem;">{{ 'customer.orders.none' | t }}</p>
            <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary">Start Shopping</a>
          </div>
        {% endif %}
      </div>

    </div>
  </div>
</div>
