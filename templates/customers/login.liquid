{% layout 'theme' %}

<div class="auth-page">
  <div class="auth-card">
    <h1 class="auth-card__title">{{ 'customer.login.title' | t }}</h1>
    <p class="auth-card__subtitle">Welcome back, fighter.</p>

    {% form 'customer_login', id: 'login-form' %}
      {% if form.errors %}
        <div class="flash-message flash-message--error">
          {{ form.errors | default_errors }}
        </div>
      {% endif %}

      <div class="auth-form">
        <div class="form-group">
          <label for="login-email">{{ 'customer.login.email' | t }}</label>
          <input
            type="email"
            id="login-email"
            name="customer[email]"
            autocomplete="email"
            required
          >
        </div>

        <div class="form-group">
          <label for="login-password">{{ 'customer.login.password' | t }}</label>
          <input
            type="password"
            id="login-password"
            name="customer[password]"
            autocomplete="current-password"
            required
          >
        </div>

        <button type="submit" class="btn btn--primary btn--full btn--lg" style="margin-top:0.5rem;">
          {{ 'customer.login.submit' | t }}
        </button>
      </div>
    {% endform %}

    <div class="auth-links">
      <a href="{{ routes.account_recover_url }}">{{ 'customer.login.forgot_password' | t }}</a>
    </div>

    <hr class="auth-divider">

    <div class="auth-links">
      {{ 'customer.login.no_account' | t }}
      <a href="{{ routes.account_register_url }}">{{ 'customer.login.create' | t }}</a>
    </div>
  </div>
</div>
