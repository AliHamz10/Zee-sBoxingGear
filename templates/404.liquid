{% layout 'theme' %}

<div class="err-pg">
  <div class="container">
    <div class="err-pg__inner">
      <div class="err-pg__num" aria-hidden="true">404</div>
      <h1 class="err-pg__title">PAGE NOT FOUND</h1>
      <p class="err-pg__msg">The page you're looking for has been moved, deleted, or doesn't exist. Let's get you back in the fight.</p>
      <div class="err-pg__actions">
        <a href="{{ routes.root_url }}" class="err-pg__btn-primary">GO HOME</a>
        <a href="{{ routes.all_products_collection_url }}" class="err-pg__btn-secondary">SHOP ALL</a>
      </div>
      <form action="{{ routes.search_url }}" method="get" class="err-pg__search" role="search">
        <input
          type="search"
          name="q"
          class="err-pg__search-input"
          placeholder="Search for gloves, bags, apparel..."
          autocomplete="off"
          aria-label="Search"
        >
        <button type="submit" class="err-pg__search-btn" aria-label="Search">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <circle cx="11" cy="11" r="8"/>
            <line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
        </button>
      </form>
    </div>
  </div>
</div>
