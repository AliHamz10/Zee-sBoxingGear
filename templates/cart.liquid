{% layout 'theme' %}

<div class="cart-pg">
  <div class="container">

    <nav class="zbg-breadcrumb" aria-label="Breadcrumb">
      <a href="{{ routes.root_url }}">Home</a>
      <span>/</span>
      <span aria-current="page">Your Cart</span>
    </nav>

    <h1 class="cart-pg__title">YOUR CART</h1>

    {% if cart.item_count > 0 %}
      <div class="cart-pg__layout">

        <!-- Items -->
        <div class="cart-pg__items">
          {% for item in cart.items %}
            <div class="cart-line" data-key="{{ item.key }}">
              <div class="cart-line__img-wrap">
                {% if item.image %}
                  <img
                    class="cart-line__img"
                    src="{{ item.image | image_url: width: 200 }}"
                    alt="{{ item.title | escape }}"
                    width="100"
                    height="100"
                  >
                {% else %}
                  <div class="cart-line__img-ph">
                    {{ 'product-1' | placeholder_svg_tag: 'cart-line__ph-svg' }}
                  </div>
                {% endif %}
              </div>

              <div class="cart-line__body">
                <div class="cart-line__top">
                  <div>
                    <p class="cart-line__name">{{ item.product.title }}</p>
                    {% unless item.variant.title == 'Default Title' %}
                      <p class="cart-line__variant">{{ item.variant.title }}</p>
                    {% endunless %}
                  </div>
                  <p class="cart-line__price">{{ item.final_line_price | money }}</p>
                </div>

                <div class="cart-line__actions">
                  <div class="cart-qty">
                    <button type="button" class="cart-qty__btn" data-qty-down data-key="{{ item.key }}" aria-label="Decrease">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/></svg>
                    </button>
                    <input
                      type="number"
                      class="cart-qty__input"
                      value="{{ item.quantity }}"
                      min="0"
                      data-qty-input
                      data-key="{{ item.key }}"
                      aria-label="Quantity for {{ item.title }}"
                    >
                    <button type="button" class="cart-qty__btn" data-qty-up data-key="{{ item.key }}" aria-label="Increase">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                    </button>
                  </div>
                  <a href="{{ item.url_to_remove }}" class="cart-line__remove">Remove</a>
                </div>
              </div>
            </div>
          {% endfor %}
        </div>

        <!-- Summary -->
        <div class="cart-pg__summary">
          <h2 class="cart-pg__summary-title">ORDER SUMMARY</h2>

          <div class="cart-pg__row">
            <span>Subtotal</span>
            <span>{{ cart.total_price | money }}</span>
          </div>

          {% if cart.cart_level_discount_applications.size > 0 %}
            {% for discount in cart.cart_level_discount_applications %}
              <div class="cart-pg__row cart-pg__row--discount">
                <span>{{ discount.title }}</span>
                <span>-{{ discount.total_allocated_amount | money }}</span>
              </div>
            {% endfor %}
          {% endif %}

          <p class="cart-pg__note">Taxes and shipping calculated at checkout.</p>

          <a href="{{ routes.checkout }}" class="cart-pg__checkout-btn">
            PROCEED TO CHECKOUT
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="{{ routes.all_products_collection_url }}" class="cart-pg__continue-btn">Continue Shopping</a>
        </div>

      </div>

    {% else %}
      <div class="cart-empty">
        <svg class="cart-empty__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
        <p class="cart-empty__msg">Your cart is empty.</p>
        <a href="{{ routes.all_products_collection_url }}" class="cart-pg__checkout-btn" style="display:inline-flex; width:auto; padding: 1rem 2.5rem;">
          START SHOPPING
        </a>
      </div>
    {% endif %}

  </div>
</div>
