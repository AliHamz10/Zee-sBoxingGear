{% liquid
  assign nav_link = link
  assign link_title = nav_link.title | default: title
  assign link_url = nav_link.url | default: url | default: '#'
  assign link_active = active
  assign normalized_title = link_title | strip | downcase
  assign is_mobile = false
  if class contains 'mobile-nav__link'
    assign is_mobile = true
  endif

  if link_active == blank and nav_link != blank
    assign link_active = nav_link.current | default: nav_link.active
  endif

  if normalized_title == 'shop all'
    assign link_url = routes.all_products_collection_url
    if request.path == routes.all_products_collection_url
      assign link_active = true
    endif
  elsif normalized_title == 'collections' or normalized_title == 'categories'
    assign link_url = '/collections'
    if request.path == '/collections'
      assign link_active = true
    endif
  endif

  assign link_classes = class | default: ''
  if link_active
    assign link_classes = link_classes | append: ' ' | append: active_class
  endif

  if link_title == 'Sale' or link_title == 'SALE'
    assign link_classes = link_classes | append: ' ' | append: sale_class
  endif

  comment
    Detect mega menu: top-level item whose children also have children
  endcomment
  assign has_mega = false
  if nav_link.links != blank and is_mobile == false
    for col in nav_link.links
      if col.links != blank
        assign has_mega = true
        break
      endif
    endfor
  endif
%}

{% if is_mobile %}
  {% comment %}── Mobile: flat link + indented children ──{% endcomment %}
  <a href="{{ link_url }}" class="{{ link_classes | strip }}">{{ link_title }}</a>
  {% if nav_link.links != blank %}
    {% for child in nav_link.links %}
      <a href="{{ child.url }}" class="mobile-nav__link mobile-nav__link--child {% if child.current %}is-active{% endif %}">
        {{ child.title }}
      </a>
      {% if child.links != blank %}
        {% for grandchild in child.links %}
          <a href="{{ grandchild.url }}" class="mobile-nav__link mobile-nav__link--grandchild {% if grandchild.current %}is-active{% endif %}">
            {{ grandchild.title }}
          </a>
        {% endfor %}
      {% endif %}
    {% endfor %}
  {% endif %}

{% elsif has_mega %}
  {% comment %}── Desktop: mega menu with column headers ──{% endcomment %}
  <div class="site-nav__item site-nav__item--has-mega">
    <a href="{{ link_url }}" class="{{ link_classes | strip }}">
      {{ link_title }}
      <svg class="site-nav__chevron" width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true">
        <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
    <div class="mega-menu" role="region">
      <div class="container">
        <div class="mega-menu__grid">
          {% for col in nav_link.links %}
            <div class="mega-menu__col">
              <a href="{{ col.url }}" class="mega-menu__heading">{{ col.title }}</a>
              {% if col.links != blank %}
                {% for item in col.links %}
                  <a href="{{ item.url }}" class="mega-menu__link {% if item.current %}is-active{% endif %}">
                    {{ item.title }}
                  </a>
                {% endfor %}
              {% endif %}
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>

{% elsif nav_link.links != blank %}
  {% comment %}── Desktop: simple dropdown (2 levels) ──{% endcomment %}
  <div class="site-nav__item site-nav__item--has-dropdown">
    <a href="{{ link_url }}" class="{{ link_classes | strip }}">
      {{ link_title }}
      <svg class="site-nav__chevron" width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true">
        <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
    <div class="site-nav__dropdown" role="region">
      <div class="container">
        <div class="site-nav__dropdown-grid">
          {% for child in nav_link.links %}
            <a href="{{ child.url }}" class="site-nav__dropdown-link {% if child.current %}is-active{% endif %}">
              {{ child.title }}
            </a>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>

{% else %}
  {% comment %}── Desktop: plain link ──{% endcomment %}
  <a href="{{ link_url }}" class="{{ link_classes | strip }}">{{ link_title }}</a>

{% endif %}
