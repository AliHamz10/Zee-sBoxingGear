{% liquid
  assign quick_add = show_quick_add
  if quick_add == blank
    assign quick_add = true
  endif

  assign primary_variant = product.selected_or_first_available_variant
%}

<article class="product-card">
  <a href="{{ product.url }}" class="product-card__media" tabindex="-1" aria-hidden="true">
    {% if product.featured_image %}
      <img
        class="product-card__img"
        src="{{ product.featured_image | image_url: width: 720 }}"
        alt="{{ product.featured_image.alt | escape | default: product.title }}"
        width="720"
        height="720"
        loading="lazy"
      >
    {% else %}
      <div class="product-card__placeholder" aria-hidden="true">
        {{ 'product-1' | placeholder_svg_tag: 'product-card__placeholder-svg' }}
      </div>
    {% endif %}

    <div class="product-card__badges">
      {% render 'badge', product: product %}
    </div>
  </a>

  <div class="product-card__body">
    {% if product.vendor != blank %}
      <p class="product-card__vendor">{{ product.vendor }}</p>
    {% endif %}

    <h3 class="product-card__title">
      <a href="{{ product.url }}">{{ product.title }}</a>
    </h3>

    <div class="product-card__price">
      {% if product.compare_at_price_max > product.price %}
        <span class="product-card__price-current product-card__price-current--sale">
          {{ product.price | money }}
        </span>
        <span class="product-card__price-compare">
          {{ product.compare_at_price_max | money }}
        </span>
      {% else %}
        <span class="product-card__price-current">
          {{ product.price | money }}
        </span>
      {% endif %}
    </div>

    {% if quick_add %}
      <div class="product-card__atc">
        {% if product.available and primary_variant %}
          <form method="post" action="{{ routes.cart_add_url }}">
            <input type="hidden" name="id" value="{{ primary_variant.id }}">
            <button type="submit" class="btn btn--primary btn--full btn--sm" aria-label="Add {{ product.title | escape }} to cart">
              Add to Cart
            </button>
          </form>
        {% else %}
          <button class="btn btn--secondary btn--full btn--sm" disabled>
            Sold Out
          </button>
        {% endif %}
      </div>
    {% endif %}
  </div>
</article>
