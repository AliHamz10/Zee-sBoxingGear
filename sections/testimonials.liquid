<section class="section testimonials">
  <div class="container">
    <div class="section-heading">
      {% if section.settings.eyebrow != blank %}
        <span class="section-heading__eyebrow">{{ section.settings.eyebrow }}</span>
      {% endif %}
      <h2 class="section-heading__title">{{ section.settings.heading | default: "What Fighters Say" }}</h2>
      {% if section.settings.subheading != blank %}
        <p class="section-heading__subtitle">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>

    <div class="testimonials-grid">
      {% for block in section.blocks %}
        {% if block.type == 'testimonial' %}
          <div class="testimonial-card" {{ block.shopify_attributes }}>
            <div class="testimonial-card__stars" aria-label="{{ block.settings.rating }} out of 5 stars">
              {% for i in (1..5) %}
                {% if i <= block.settings.rating %}
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                {% else %}
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                {% endif %}
              {% endfor %}
            </div>
            <p class="testimonial-card__text">"{{ block.settings.text }}"</p>
            <div class="testimonial-card__author">
              <div class="testimonial-card__avatar" aria-hidden="true">
                {{ block.settings.name | slice: 0, 1 | upcase }}
              </div>
              <div>
                <div class="testimonial-card__name">{{ block.settings.name }}</div>
                {% if block.settings.location != blank %}
                  <div class="testimonial-card__location">{{ block.settings.location }}</div>
                {% endif %}
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "Customer Reviews"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Fighters Say"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Real gear. Real results. Trusted by fighters worldwide."
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Customer Name",
          "default": "Alex M."
        },
        {
          "type": "text",
          "id": "location",
          "label": "Location",
          "default": "New York, USA"
        },
        {
          "type": "range",
          "id": "rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "label": "Star Rating",
          "default": 5
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Review Text",
          "default": "Best boxing gloves I've ever used. The quality is unmatched and they arrived fast. Highly recommend Zee's Boxing Gear!"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "name": "Marcus J.",
            "location": "London, UK",
            "rating": 5,
            "text": "Absolutely love my new gloves. Perfect fit, great protection. These are the real deal — I train 5 days a week and they hold up perfectly."
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "name": "Sarah K.",
            "location": "Toronto, Canada",
            "rating": 5,
            "text": "Finally found gear that actually fits well and looks great. Shipped faster than expected. Will definitely be ordering again!"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "name": "Diego R.",
            "location": "Sydney, Australia",
            "rating": 5,
            "text": "The head guard is incredible. Super comfortable and I feel fully protected during sparring. Zee's Boxing Gear is my go-to now."
          }
        }
      ]
    }
  ]
}
{% endschema %}
