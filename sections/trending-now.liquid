{% liquid
  assign section_id = section.id
%}

<section class="tn" id="tn-{{ section_id }}">
  <div class="tn__header">
    <h2 class="tn__title">{{ section.settings.heading | default: 'TRENDING NOW' }}</h2>
    <nav class="tn__tabs" aria-label="Product filter tabs">
      {% for block in section.blocks %}
        <button
          class="tn__tab{% if forloop.first %} is-active{% endif %}"
          data-tn-btn="{{ section_id }}-{{ forloop.index0 }}"
          type="button"
          {{ block.shopify_attributes }}
        >{{ block.settings.label | default: 'Tab' }}</button>
      {% endfor %}
    </nav>
  </div>

  <div class="tn__panels">
    {% for block in section.blocks %}
      {% liquid
        assign col = blank
        if block.settings.collection != blank
          assign col = collections[block.settings.collection]
        endif

        assign pid = section_id | append: '-' | append: forloop.index0
        assign is_first = forloop.first

        assign edit_img = block.settings.editorial_image
        if edit_img == blank
          assign edit_img = section.settings.editorial_image
        endif
        assign edit_alt = block.settings.editorial_alt | default: section.settings.editorial_alt | default: 'Featured athlete'

        assign demo_names = 'Pro Sparring Gloves,Speed Bag Platform,Elite Boxing Shoes,Heavy Bag 100 lb,Compression Shorts,Head Guard Pro,Training Mitts,Skipping Rope Pro' | split: ','
        assign demo_prices = '19999,11999,12999,18999,3499,8999,5499,2499' | split: ','
        assign demo_was = '24999,0,16999,22999,0,11999,6999,0' | split: ','
        assign demo_colors = '4,0,3,2,5,0,2,4' | split: ','
        assign demo_svgs = '1,2,3,4,5,6,1,2' | split: ','
        assign shown_products = 0
      %}

      <div
        class="tn__panel{% if is_first %} is-active{% endif %}"
        data-tn-panel="{{ pid }}"
        aria-hidden="{% unless is_first %}true{% endunless %}"
      >
        <div class="tn__track" id="tn-track-{{ pid }}">
          <div class="tn__editorial">
            {% if edit_img %}
              <img
                src="{{ edit_img | image_url: width: 900 }}"
                alt="{{ edit_alt | escape }}"
                width="900"
                height="1080"
                loading="lazy"
              >
            {% else %}
              <div class="tn__editorial-ph">
                <div class="tn__editorial-ph-content">
                  <svg class="tn__editorial-ph-icon" width="52" height="52" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <rect x="3" y="3" width="18" height="18" rx="2.5" />
                    <circle cx="8.5" cy="8.5" r="1.5" />
                    <polyline points="21 15 16 10 5 21" />
                  </svg>
                  <p class="tn__editorial-ph-label">Add editorial image<br>in Customizer</p>
                </div>
              </div>
            {% endif %}
          </div>

          {% if col != blank and col.products_count > 0 %}
            {% for product in col.products limit: section.settings.products_per_tab %}
              {% liquid
                assign shown_products = shown_products | plus: 1
                assign is_sale = false
                assign color_count = 0
                assign color_opt_idx = nil
                if product.compare_at_price_max > product.price
                  assign is_sale = true
                endif

                assign opt_i = 0
                for opt_name in product.options
                  assign opt_lower = opt_name | downcase
                  if opt_lower == 'color' or opt_lower == 'colour'
                    assign color_opt_idx = opt_i
                  endif
                  assign opt_i = opt_i | plus: 1
                endfor

                for ov in product.options_with_values
                  assign o_name = ov.name | downcase
                  if o_name == 'color' or o_name == 'colour'
                    assign color_count = ov.values.size
                    break
                  endif
                endfor

                assign img2 = product.images[1]
              %}

              <article class="tn-card" data-product-card>
                <a href="{{ product.url }}" class="tn-card__media" tabindex="-1" aria-hidden="true">
                  {% if is_sale %}<span class="tn-card__badge">Sale</span>{% endif %}

                  {% if product.featured_image %}
                    <img
                      class="tn-card__img tn-card__img--primary"
                      src="{{ product.featured_image | image_url: width: 640 }}"
                      alt="{{ product.featured_image.alt | escape | default: product.title }}"
                      width="640"
                      height="640"
                      loading="lazy"
                    >
                  {% else %}
                    <div class="tn-card__ph tn-card__ph--a">
                      {{ 'product-1' | placeholder_svg_tag: 'tn-card__svg' }}
                    </div>
                  {% endif %}

                  {% if img2 %}
                    <img
                      class="tn-card__img tn-card__img--secondary"
                      src="{{ img2 | image_url: width: 640 }}"
                      alt="{{ img2.alt | escape | default: product.title }}"
                      width="640"
                      height="640"
                      loading="lazy"
                    >
                  {% else %}
                    <div class="tn-card__ph tn-card__ph--b">
                      {{ 'product-2' | placeholder_svg_tag: 'tn-card__svg' }}
                    </div>
                  {% endif %}
                </a>

                <div class="tn-card__info">
                  <h3 class="tn-card__name"><a href="{{ product.url }}">{{ product.title }}</a></h3>
                  <p class="tn-card__price">
                    {% if is_sale %}
                      <s class="tn-card__was">{{ product.compare_at_price_max | money }}</s>
                      <span class="tn-card__now">{{ product.price | money }}</span>
                    {% else %}
                      <span class="tn-card__now tn-card__now--reg">{{ product.price | money }}</span>
                    {% endif %}
                  </p>

                  {% if color_count > 0 and color_opt_idx != nil %}
                    <div class="tn-card__colors-wrap">
                      <button class="tn-card__colors" type="button" data-swatch-toggle aria-expanded="false">
                        <span>{{ color_count }}&nbsp;Color{% if color_count > 1 %}s{% endif %}</span>
                        <svg class="tn-card__chevron" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9" /></svg>
                      </button>

                      <div class="tn-card__swatches" hidden>
                        {% assign seen_colors = '' %}
                        {% for variant in product.variants limit: 20 %}
                          {% liquid
                            assign vc = variant.options[color_opt_idx]
                            assign vc_slug = vc | handleize
                            assign swatch_img = ''
                            assign swatch_bg = ''
                            if variant.featured_media
                              assign swatch_img = variant.featured_media.preview_image | image_url: width: 640
                              assign swatch_bg = variant.featured_media.preview_image | image_url: width: 80
                            endif
                          %}
                          {% unless seen_colors contains vc_slug %}
                            {% assign seen_colors = seen_colors | append: vc_slug | append: '|' %}
                            <button
                              class="tn-card__swatch{% if forloop.first %} is-active{% endif %}"
                              type="button"
                              aria-label="{{ vc | escape }}"
                              title="{{ vc | escape }}"
                              {% if swatch_img != blank %}data-swatch-img="{{ swatch_img }}"{% endif %}
                              {% if swatch_bg != blank %}style="background-image:url('{{ swatch_bg }}');"{% endif %}
                            ></button>
                          {% endunless %}
                        {% endfor %}
                      </div>
                    </div>
                  {% endif %}

                  <div class="tn-card__stars" aria-label="Rating"><span aria-hidden="true">★★★★★</span></div>
                </div>
              </article>
            {% endfor %}
          {% endif %}

          {% assign demo_needed = section.settings.products_per_tab | minus: shown_products %}
          {% if demo_needed > 0 %}
            {% for demo_name in demo_names limit: demo_needed %}
              {% liquid
                assign demo_index = forloop.index0
                assign demo_price = demo_prices[demo_index] | plus: 0
                assign demo_compare = demo_was[demo_index] | plus: 0
                assign demo_color_count = demo_colors[demo_index] | plus: 0
                assign demo_svg = demo_svgs[demo_index]
                assign swatch_palette = '#c8111b,#111111,#d7d7d7,#1a4fa0,#e8c200' | split: ','
              %}

              <article class="tn-card" data-product-card>
                <div class="tn-card__media">
                  {% if demo_compare > 0 %}<span class="tn-card__badge">Sale</span>{% endif %}
                  <div class="tn-card__ph tn-card__ph--a">
                    {{ 'product-' | append: demo_svg | placeholder_svg_tag: 'tn-card__svg' }}
                  </div>
                  <div class="tn-card__ph tn-card__ph--b">
                    {{ 'product-' | append: demo_svg | placeholder_svg_tag: 'tn-card__svg' }}
                  </div>
                </div>

                <div class="tn-card__info">
                  <h3 class="tn-card__name"><span>{{ demo_name }}</span></h3>
                  <p class="tn-card__price">
                    {% if demo_compare > 0 %}
                      <s class="tn-card__was">{{ demo_compare | money }}</s>
                      <span class="tn-card__now">{{ demo_price | money }}</span>
                    {% else %}
                      <span class="tn-card__now tn-card__now--reg">{{ demo_price | money }}</span>
                    {% endif %}
                  </p>

                  {% if demo_color_count > 0 %}
                    <div class="tn-card__colors-wrap">
                      <button class="tn-card__colors" type="button" data-swatch-toggle aria-expanded="false">
                        <span>{{ demo_color_count }}&nbsp;Color{% if demo_color_count > 1 %}s{% endif %}</span>
                        <svg class="tn-card__chevron" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9" /></svg>
                      </button>
                      <div class="tn-card__swatches" hidden>
                        {% for swatch in swatch_palette limit: demo_color_count %}
                          <button class="tn-card__swatch{% if forloop.first %} is-active{% endif %}" type="button" aria-label="Color {{ forloop.index }}" style="background-color:{{ swatch }};"></button>
                        {% endfor %}
                      </div>
                    </div>
                  {% endif %}

                  <div class="tn-card__stars" aria-label="Rating"><span aria-hidden="true">★★★★★</span></div>
                </div>
              </article>
            {% endfor %}
          {% endif %}
        </div>

        <div class="tn__nav">
          <div class="tn__progress-wrap">
            <div class="tn__progress-bar" data-tn-prog="{{ pid }}"></div>
          </div>
          <p class="tn__counter">
            <span data-tn-cur="{{ pid }}">1</span>&nbsp;/&nbsp;<span data-tn-tot="{{ pid }}">1</span>
          </p>
        </div>
      </div>
    {% endfor %}
  </div>
</section>

<script>
(function () {
  var ROOT = document.getElementById('tn-{{ section_id }}');
  if (!ROOT) return;

  var SWITCH_MS = 420;
  var CAR = {};

  function qs(sel, ctx) {
    return (ctx || ROOT).querySelector(sel);
  }

  function qsa(sel, ctx) {
    return Array.prototype.slice.call((ctx || ROOT).querySelectorAll(sel));
  }

  function staggerCards(panel) {
    qsa('[data-product-card]', panel).forEach(function(card, i) {
      card.style.opacity = '0';
      card.style.transform = 'translate3d(0, 12px, 0)';
      card.style.transition = 'none';

      requestAnimationFrame(function() {
        requestAnimationFrame(function() {
          var delay = (i * 36 + 50) + 'ms';
          card.style.transition = 'opacity .34s ease ' + delay + ', transform .34s cubic-bezier(.22,1,.36,1) ' + delay;
          card.style.opacity = '1';
          card.style.transform = 'translate3d(0, 0, 0)';
        });
      });
    });
  }

  function bindTabs() {
    qsa('[data-tn-btn]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        if (btn.classList.contains('is-active')) return;

        qsa('[data-tn-btn]').forEach(function(otherBtn) {
          otherBtn.classList.remove('is-active');
        });
        btn.classList.add('is-active');

        var panels = qs('.tn__panels');
        var entering = qs('[data-tn-panel="' + btn.dataset.tnBtn + '"]');
        var leaving = qs('[data-tn-panel].is-active');
        if (!entering || entering === leaving) return;

        if (leaving) {
          leaving.classList.remove('is-active', 'is-entering');
          leaving.classList.add('is-leaving');
          leaving.setAttribute('aria-hidden', 'true');
          window.setTimeout(function() {
            leaving.classList.remove('is-leaving');
          }, SWITCH_MS);
        }

        entering.classList.remove('is-leaving', 'is-entering');
        entering.classList.add('is-active');
        entering.setAttribute('aria-hidden', 'false');
        panels.style.minHeight = Math.max(leaving ? leaving.offsetHeight : 0, entering.offsetHeight) + 'px';

        void entering.offsetWidth;
        entering.classList.add('is-entering');

        window.setTimeout(function() {
          entering.classList.remove('is-entering');
          panels.style.minHeight = '';
        }, SWITCH_MS);

        initCarousel(btn.dataset.tnBtn);
        syncScroll(btn.dataset.tnBtn);
        staggerCards(entering);
      });
    });
  }

  function initCarousel(pid) {
    var track = document.getElementById('tn-track-' + pid);
    var progEl = qs('[data-tn-prog="' + pid + '"]');
    var curEl = qs('[data-tn-cur="' + pid + '"]');
    var totEl = qs('[data-tn-tot="' + pid + '"]');
    var cards;
    var sx = 0;
    var scrollTimer;

    if (!track) return;

    cards = qsa('[data-product-card]', track);
    if (!cards.length) return;

    if (!CAR[pid]) {
      CAR[pid] = {
        track: track,
        progEl: progEl,
        curEl: curEl,
        totEl: totEl,
        cards: cards
      };

      track.addEventListener('scroll', function() {
        window.clearTimeout(scrollTimer);
        scrollTimer = window.setTimeout(function() {
          syncScroll(pid);
        }, 40);
      }, { passive: true });

      track.addEventListener('touchstart', function(e) {
        sx = e.touches[0].clientX;
      }, { passive: true });

      track.addEventListener('touchend', function(e) {
        var dx = e.changedTouches[0].clientX - sx;
        var cardWidth;

        if (Math.abs(dx) <= 44) return;
        cardWidth = cards[0] ? cards[0].getBoundingClientRect().width : 100;
        track.scrollBy({ left: (dx < 0 ? 1 : -1) * cardWidth, behavior: 'smooth' });
      }, { passive: true });
    } else {
      CAR[pid].track = track;
      CAR[pid].progEl = progEl;
      CAR[pid].curEl = curEl;
      CAR[pid].totEl = totEl;
      CAR[pid].cards = cards;
    }

    if (totEl) totEl.textContent = cards.length;
    syncScroll(pid);
  }

  function getGap(pid) {
    var c = CAR[pid];
    return c ? (parseFloat(getComputedStyle(c.track).columnGap || 0) || 0) : 0;
  }

  function syncScroll(pid) {
    var c = CAR[pid];
    var maxScroll;
    var editorial;
    var editorialWidth;
    var cardWidth;
    var productScroll;
    var idx;

    if (!c) return;

    maxScroll = c.track.scrollWidth - c.track.clientWidth;
    if (c.progEl) {
      c.progEl.style.width = (maxScroll > 0 ? Math.min(100, c.track.scrollLeft / maxScroll * 100) : 0) + '%';
    }

    if (!c.cards.length || !c.curEl) return;

    editorial = c.track.querySelector('.tn__editorial');
    editorialWidth = editorial ? editorial.getBoundingClientRect().width + getGap(pid) : 0;
    cardWidth = c.cards[0].getBoundingClientRect().width + getGap(pid);
    productScroll = Math.max(0, c.track.scrollLeft - editorialWidth);
    idx = Math.min(Math.round(productScroll / cardWidth), c.cards.length - 1);
    c.curEl.textContent = idx + 1;
  }

  ROOT.addEventListener('click', function(e) {
    var toggleBtn = e.target.closest('[data-swatch-toggle]');
    var swatch;
    var swatches;
    var primary;

    if (toggleBtn) {
      swatches = toggleBtn.closest('.tn-card__colors-wrap');
      if (!swatches) return;
      swatches = swatches.querySelector('.tn-card__swatches');
      if (!swatches) return;
      toggleBtn.setAttribute('aria-expanded', toggleBtn.getAttribute('aria-expanded') === 'true' ? 'false' : 'true');
      swatches.hidden = !swatches.hidden;
      return;
    }

    swatch = e.target.closest('.tn-card__swatch');
    if (!swatch) return;

    primary = swatch.closest('.tn-card').querySelector('.tn-card__img--primary');
    if (primary && swatch.dataset.swatchImg) {
      primary.src = swatch.dataset.swatchImg;
    }

    swatch.closest('.tn-card__swatches').querySelectorAll('.tn-card__swatch').forEach(function(other) {
      other.classList.remove('is-active');
    });
    swatch.classList.add('is-active');
  });

  bindTabs();

  var first = qs('[data-tn-panel].is-active');
  if (first) {
    initCarousel(first.dataset.tnPanel);
    staggerCards(first);
  }

  var resizeTimer;
  window.addEventListener('resize', function() {
    window.clearTimeout(resizeTimer);
    resizeTimer = window.setTimeout(function() {
      Object.keys(CAR).forEach(syncScroll);
    }, 200);
  });
})();
</script>

{% schema %}
{
  "name": "Trending Now",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "TRENDING NOW"
    },
    {
      "type": "image_picker",
      "id": "editorial_image",
      "label": "Default editorial image"
    },
    {
      "type": "text",
      "id": "editorial_alt",
      "label": "Default editorial alt text",
      "default": "Featured athlete"
    },
    {
      "type": "range",
      "id": "products_per_tab",
      "label": "Max products per tab",
      "min": 4,
      "max": 14,
      "step": 1,
      "default": 8
    }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Tab",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Tab label",
          "default": "BEST SELLERS"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "editorial_image",
          "label": "Editorial image (overrides default)"
        },
        {
          "type": "text",
          "id": "editorial_alt",
          "label": "Editorial alt text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trending Now",
      "blocks": [
        { "type": "tab", "settings": { "label": "BEST SELLERS" } },
        { "type": "tab", "settings": { "label": "BOXING GLOVES" } },
        { "type": "tab", "settings": { "label": "EQUIPMENT" } }
      ]
    }
  ]
}
{% endschema %}
