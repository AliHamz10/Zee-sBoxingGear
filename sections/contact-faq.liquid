<div class="container">
  <!-- Breadcrumb -->
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="{{ routes.root_url }}">Home</a>
    <span>/</span>
    <span aria-current="page">Contact &amp; FAQ</span>
  </nav>
</div>

<!-- Page Header -->
<div class="collection-header">
  <div class="container">
    <h1>{{ section.settings.heading | default: "Contact & FAQ" }}</h1>
    {% if section.settings.subheading != blank %}
      <p>{{ section.settings.subheading }}</p>
    {% endif %}
  </div>
</div>

<section class="contact-page">
  <div class="container">
    <div class="contact-page__inner">

      <!-- Contact Form -->
      <div>
        <h2 style="color:var(--color-primary); font-size:1.5rem; margin-bottom:1.5rem;">Send Us a Message</h2>

        {% form 'contact', id: 'contact-form' %}
          {% if form.posted_successfully? %}
            <div class="flash-message flash-message--success">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; margin-top:1px;">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              {{ 'contact.form.success' | t }}
            </div>
          {% endif %}

          {% if form.errors %}
            <div class="flash-message flash-message--error">
              {{ form.errors | default_errors }}
            </div>
          {% endif %}

          <div class="contact-form">
            <div class="form-group">
              <label for="contact-name">{{ 'contact.form.name' | t }} <span style="color:#c0392b;">*</span></label>
              <input
                type="text"
                id="contact-name"
                name="contact[name]"
                value="{{ form.name }}"
                required
                autocomplete="name"
              >
            </div>

            <div class="form-group">
              <label for="contact-email">{{ 'contact.form.email' | t }} <span style="color:#c0392b;">*</span></label>
              <input
                type="email"
                id="contact-email"
                name="contact[email]"
                value="{{ form.email }}"
                required
                autocomplete="email"
              >
            </div>

            <div class="form-group">
              <label for="contact-phone">{{ 'contact.form.phone' | t }}</label>
              <input
                type="tel"
                id="contact-phone"
                name="contact[phone]"
                value="{{ form.phone }}"
                autocomplete="tel"
              >
            </div>

            <div class="form-group">
              <label for="contact-subject">{{ 'contact.form.subject' | t }}</label>
              <select id="contact-subject" name="contact[subject]">
                <option value="">Select a topic...</option>
                <option value="Order Inquiry">Order Inquiry</option>
                <option value="Shipping Question">Shipping Question</option>
                <option value="Return / Refund">Return / Refund</option>
                <option value="Product Question">Product Question</option>
                <option value="Other">Other</option>
              </select>
            </div>

            <div class="form-group">
              <label for="contact-message">{{ 'contact.form.message' | t }} <span style="color:#c0392b;">*</span></label>
              <textarea
                id="contact-message"
                name="contact[body]"
                required
                rows="5"
              >{{ form.body }}</textarea>
            </div>

            <button type="submit" class="btn btn--primary btn--full">
              {{ 'contact.form.submit' | t }}
            </button>
          </div>
        {% endform %}
      </div>

      <!-- FAQ -->
      <div>
        <h2 style="color:var(--color-primary); font-size:1.5rem; margin-bottom:1.5rem;">Frequently Asked Questions</h2>

        <div class="faq-list" id="faq-list">
          {% for block in section.blocks %}
            {% if block.type == 'faq' %}
              <div class="faq-item" {{ block.shopify_attributes }}>
                <button
                  class="faq-question"
                  aria-expanded="false"
                  aria-controls="faq-answer-{{ forloop.index }}"
                >
                  {{ block.settings.question }}
                  <span class="faq-question__icon" aria-hidden="true">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                      <line x1="12" y1="5" x2="12" y2="19"></line>
                      <line x1="5" y1="12" x2="19" y2="12"></line>
                    </svg>
                  </span>
                </button>
                <div
                  class="faq-answer"
                  id="faq-answer-{{ forloop.index }}"
                  role="region"
                >
                  <div class="faq-answer__inner">{{ block.settings.answer }}</div>
                </div>
              </div>
            {% endif %}
          {% endfor %}
        </div>

        <!-- Contact Info -->
        <div style="margin-top:2.5rem; padding:1.5rem; background:#f4f7fa; border-radius:8px;">
          <h3 style="font-size:1.1rem; color:var(--color-primary); margin-bottom:1rem;">Other Ways to Reach Us</h3>
          {% if section.settings.email != blank %}
            <p style="font-size:0.9rem; margin-bottom:0.5rem;">
              <strong>Email:</strong>
              <a href="mailto:{{ section.settings.email }}" style="color:var(--color-secondary);">{{ section.settings.email }}</a>
            </p>
          {% endif %}
          {% if section.settings.response_time != blank %}
            <p style="font-size:0.85rem; color:#888;">{{ section.settings.response_time }}</p>
          {% endif %}
        </div>
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Contact & FAQ",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Page Heading",
      "default": "Contact & FAQ"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Page Subheading",
      "default": "We're here to help. Reach out or find your answer below."
    },
    {
      "type": "text",
      "id": "email",
      "label": "Support Email",
      "default": "support@zeesboxinggear.com"
    },
    {
      "type": "text",
      "id": "response_time",
      "label": "Response Time Note",
      "default": "We typically respond within 24-48 hours, Monday–Friday."
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "What is your return policy?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>We accept returns within 30 days of purchase. Items must be unused and in original packaging. Please contact us to initiate a return.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Contact & FAQ",
      "blocks": [
        {
          "type": "faq",
          "settings": {
            "question": "How long does shipping take?",
            "answer": "<p>We ship worldwide. Domestic orders typically arrive within 3–7 business days. International orders take 7–21 business days depending on location.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "What is your return policy?",
            "answer": "<p>We accept returns within 30 days of purchase on unused items in original packaging. Contact us at support@zeesboxinggear.com to initiate a return.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "How do I choose the right glove size?",
            "answer": "<p>Glove sizing is based on your body weight. Under 60kg: 10oz, 60–80kg: 12oz, 80kg+: 14–16oz. Each product page includes a full sizing guide.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Do you offer discount codes?",
            "answer": "<p>Yes! Subscribe to our newsletter to receive exclusive discount codes. We also run seasonal sales — follow us on social media to stay updated.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Can I track my order?",
            "answer": "<p>Absolutely. Once your order ships, you'll receive an email with a tracking number. You can also log in to your account to view order status.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
