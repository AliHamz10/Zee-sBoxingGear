<!-- Page Header -->
<div class="pg-hdr">
  <div class="container">
    <nav class="zbg-breadcrumb" aria-label="Breadcrumb">
      <a href="{{ routes.root_url }}">Home</a>
      <span>/</span>
      <span aria-current="page">Contact &amp; FAQ</span>
    </nav>
    <h1 class="pg-hdr__title">{{ section.settings.heading | default: 'CONTACT & FAQ' }}</h1>
    {% if section.settings.subheading != blank %}
      <p class="pg-hdr__sub">{{ section.settings.subheading }}</p>
    {% else %}
      <p class="pg-hdr__sub">We're here to help. Reach out or find your answer below.</p>
    {% endif %}
  </div>
</div>

<section class="cfaq">
  <div class="container">
    <div class="cfaq__inner">

      <!-- Contact Form -->
      <div class="cfaq__form-col">
        <h2 class="cfaq__col-title">SEND A MESSAGE</h2>

        {% form 'contact', id: 'contact-form' %}
          {% if form.posted_successfully? %}
            <div class="cfaq__success">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              Message sent! We'll get back to you within 24–48 hours.
            </div>
          {% endif %}

          {% if form.errors %}
            <div class="cfaq__error">{{ form.errors | default_errors }}</div>
          {% endif %}

          <div class="cfaq__fields">
            <div class="cfaq__field">
              <label for="cfaq-name" class="cfaq__label">Full Name <span aria-hidden="true">*</span></label>
              <input type="text" id="cfaq-name" name="contact[name]" value="{{ form.name }}" class="cfaq__input" required placeholder="John Doe">
            </div>

            <div class="cfaq__field">
              <label for="cfaq-email" class="cfaq__label">Email Address <span aria-hidden="true">*</span></label>
              <input type="email" id="cfaq-email" name="contact[email]" value="{{ form.email }}" class="cfaq__input" required placeholder="your@email.com">
            </div>

            <div class="cfaq__field">
              <label for="cfaq-subject" class="cfaq__label">Topic</label>
              <div class="cfaq__select-wrap">
                <select id="cfaq-subject" name="contact[subject]" class="cfaq__select">
                  <option value="">Select a topic...</option>
                  <option value="Order Inquiry">Order Inquiry</option>
                  <option value="Shipping Question">Shipping Question</option>
                  <option value="Return / Refund">Return / Refund</option>
                  <option value="Product Question">Product Question</option>
                  <option value="Other">Other</option>
                </select>
                <svg class="cfaq__select-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
              </div>
            </div>

            <div class="cfaq__field">
              <label for="cfaq-msg" class="cfaq__label">Message <span aria-hidden="true">*</span></label>
              <textarea id="cfaq-msg" name="contact[body]" class="cfaq__textarea" required rows="5" placeholder="Tell us how we can help...">{{ form.body }}</textarea>
            </div>

            <button type="submit" class="cfaq__submit-btn">SEND MESSAGE</button>
          </div>
        {% endform %}

        <!-- Contact Info -->
        <div class="cfaq__contact-info">
          <h3 class="cfaq__info-title">OTHER WAYS TO REACH US</h3>
          {% if section.settings.email != blank %}
            <div class="cfaq__info-row">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              <a href="mailto:{{ section.settings.email }}">{{ section.settings.email }}</a>
            </div>
          {% else %}
            <div class="cfaq__info-row">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              <a href="mailto:support@zeesboxinggear.com">support@zeesboxinggear.com</a>
            </div>
          {% endif %}
          <p class="cfaq__info-note">
            {{ section.settings.response_time | default: 'We typically respond within 24–48 hours, Monday–Friday.' }}
          </p>
        </div>
      </div>

      <!-- FAQ -->
      <div class="cfaq__faq-col">
        <h2 class="cfaq__col-title">FREQUENTLY ASKED QUESTIONS</h2>

        <div class="cfaq__faq-list" id="cfaq-faq-list">
          {% for block in section.blocks %}
            {% if block.type == 'faq' %}
              <div class="cfaq__faq-item" {{ block.shopify_attributes }}>
                <button
                  class="cfaq__faq-q"
                  aria-expanded="false"
                  aria-controls="cfaq-a-{{ forloop.index }}"
                  id="cfaq-q-{{ forloop.index }}"
                >
                  <span>{{ block.settings.question }}</span>
                  <svg class="cfaq__faq-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                    <line x1="12" y1="5" x2="12" y2="19"/>
                    <line x1="5" y1="12" x2="19" y2="12"/>
                  </svg>
                </button>
                <div
                  class="cfaq__faq-a"
                  id="cfaq-a-{{ forloop.index }}"
                  role="region"
                  aria-labelledby="cfaq-q-{{ forloop.index }}"
                  hidden
                >
                  <div class="cfaq__faq-a-inner">{{ block.settings.answer }}</div>
                </div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>

    </div>
  </div>
</section>

<script>
(function () {
  var items = document.querySelectorAll('.cfaq__faq-item');
  items.forEach(function (item) {
    var btn = item.querySelector('.cfaq__faq-q');
    var ans = item.querySelector('.cfaq__faq-a');
    var icon = item.querySelector('.cfaq__faq-icon');
    if (!btn || !ans) return;
    btn.addEventListener('click', function () {
      var isOpen = btn.getAttribute('aria-expanded') === 'true';
      items.forEach(function (it) {
        it.querySelector('.cfaq__faq-q').setAttribute('aria-expanded', 'false');
        it.querySelector('.cfaq__faq-a').hidden = true;
        it.querySelector('.cfaq__faq-icon').style.transform = '';
        it.classList.remove('is-open');
      });
      if (!isOpen) {
        btn.setAttribute('aria-expanded', 'true');
        ans.hidden = false;
        icon.style.transform = 'rotate(45deg)';
        item.classList.add('is-open');
      }
    });
  });
})();
</script>

{% schema %}
{
  "name": "Contact & FAQ",
  "settings": [
    { "type": "text", "id": "heading", "label": "Page Heading", "default": "CONTACT & FAQ" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "We're here to help. Reach out or find your answer below." },
    { "type": "text", "id": "email", "label": "Support Email", "default": "support@zeesboxinggear.com" },
    { "type": "text", "id": "response_time", "label": "Response Time Note", "default": "We typically respond within 24–48 hours, Monday–Friday." }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ Item",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "What is your return policy?" },
        { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>We accept returns within 30 days of purchase. Items must be unused and in original packaging.</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Contact & FAQ",
      "blocks": [
        { "type": "faq", "settings": { "question": "How long does shipping take?", "answer": "<p>Domestic orders typically arrive within 3–7 business days. International orders take 7–21 business days depending on location.</p>" } },
        { "type": "faq", "settings": { "question": "What is your return policy?", "answer": "<p>We accept returns within 30 days on unused items in original packaging. Contact support@zeesboxinggear.com to initiate a return.</p>" } },
        { "type": "faq", "settings": { "question": "How do I choose the right glove size?", "answer": "<p>Glove sizing is based on body weight. Under 60kg: 10oz, 60–80kg: 12oz, 80kg+: 14–16oz. Each product page includes a full sizing guide.</p>" } },
        { "type": "faq", "settings": { "question": "Do you offer discount codes?", "answer": "<p>Yes! Subscribe to our newsletter to receive exclusive discount codes. We also run seasonal sales — follow us on social media.</p>" } },
        { "type": "faq", "settings": { "question": "Can I track my order?", "answer": "<p>Absolutely. Once your order ships, you'll receive an email with a tracking number. You can also log in to your account to view order status.</p>" } }
      ]
    }
  ]
}
{% endschema %}
