{% liquid
  assign featured_collection = section.settings.collection

  if featured_collection != blank and featured_collection.products_count == blank
    assign featured_collection = collections[section.settings.collection]
  endif

  if featured_collection == blank
    assign featured_collection = collections['all']
  endif
%}

<section class="section section-featured-products">
  <div class="container">
    <div class="section-heading section-heading--split">
      <div>
        {% if section.settings.eyebrow != blank %}
          <p class="section-heading__eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}
        <h2 class="section-heading__title">{{ section.settings.heading }}</h2>
        {% if section.settings.subheading != blank %}
          <p class="section-heading__subtitle section-heading__subtitle--left">{{ section.settings.subheading }}</p>
        {% endif %}
      </div>

      {% if featured_collection != blank and section.settings.show_view_all %}
        <a href="{{ featured_collection.url | default: routes.all_products_collection_url }}" class="btn btn--secondary">
          {{ section.settings.view_all_label }}
        </a>
      {% endif %}
    </div>

    {% if featured_collection != blank and featured_collection.products_count > 0 %}
      <div class="product-grid product-grid--homepage">
        {% for product in featured_collection.products limit: 5 %}
          {% render 'product-card', product: product, show_quick_add: section.settings.show_quick_add %}
        {% endfor %}
      </div>
    {% else %}
      <div class="section-empty-state">
        <p>Add products to your selected Shopify collection and the first 5 will show here automatically.</p>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Featured Products",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Built For Training"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Gear"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Use a real Shopify collection to keep this grid fresh without touching code."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "checkbox",
      "id": "show_quick_add",
      "label": "Show quick add button",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show view all button",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View all button label",
      "default": "View Collection"
    }
  ],
  "presets": [
    {
      "name": "Featured Products"
    }
  ]
}
{% endschema %}
