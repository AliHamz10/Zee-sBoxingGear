<section class="section section-category">
  <div class="container">
    <div class="section-heading">
      {% if section.settings.eyebrow != blank %}
        <p class="section-heading__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      <h2 class="section-heading__title">{{ section.settings.heading | default: "Shop By Category" }}</h2>
      {% if section.settings.subheading != blank %}
        <p class="section-heading__subtitle">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>

    <div class="category-grid">
      {% for block in section.blocks %}
        {% if block.type == 'category' %}
          {% liquid
            assign linked_collection = blank
            assign collection_handle = blank
            assign normalized_label_handle = block.settings.label | handleize

            if block.settings.collection != blank
              assign linked_collection = collections[block.settings.collection]
            elsif block.settings.url contains '/collections/'
              assign collection_handle = block.settings.url | split: '/collections/' | last | split: '?' | first | split: '#' | first | split: '/' | first
              if collection_handle != blank
                assign linked_collection = collections[collection_handle]
              endif
            endif

            if linked_collection == blank and normalized_label_handle != blank
              assign linked_collection = collections[normalized_label_handle]
            endif

            assign card_url = block.settings.url | default: '#'
            if linked_collection != blank
              assign card_url = linked_collection.url
            elsif normalized_label_handle != blank
              assign card_url = '/collections/' | append: normalized_label_handle
            endif

            assign card_label = block.settings.label
            if card_label == blank and linked_collection != blank
              assign card_label = linked_collection.title
            endif

            assign card_image = block.settings.image
            if card_image == blank and linked_collection != blank
              if linked_collection.image != blank
                assign card_image = linked_collection.image
              elsif linked_collection.products.first.featured_image != blank
                assign card_image = linked_collection.products.first.featured_image
              endif
            endif
          %}

          <div {{ block.shopify_attributes }}>
            {% render 'collection-card',
              collection: linked_collection,
              title: card_label,
              url: card_url,
              image: card_image,
              class: 'collection-card--category'
            %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Shop By Category",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Collections" },
    { "type": "text", "id": "heading", "label": "Section Heading", "default": "Shop By Category" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Use real Shopify collections so imagery, titles, and links stay in sync." }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category Card",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "image_picker", "id": "image", "label": "Category Image" },
        { "type": "text", "id": "label", "label": "Category Name", "default": "GLOVES" },
        { "type": "url", "id": "url", "label": "Link URL" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop By Category",
      "blocks": [
        { "type": "category", "settings": { "label": "GLOVES" } },
        { "type": "category", "settings": { "label": "PROTECTIVE GEAR" } },
        { "type": "category", "settings": { "label": "TRAINING EQUIPMENT" } }
      ]
    }
  ]
}
{% endschema %}
