<section class="section-category">
  <div class="container">
    <h2 class="section-title-plain">{{ section.settings.heading | default: "Shop By Category" }}</h2>
  </div>

  <div class="category-grid">
    {% for block in section.blocks %}
      {% if block.type == 'category' %}
        <a href="{{ block.settings.url | default: '#' }}" class="category-card" {{ block.shopify_attributes }}>
          <div class="category-card__img-wrap">
            {% if block.settings.image %}
              <img
                src="{{ block.settings.image | image_url: width: 900 }}"
                alt="{{ block.settings.label }}"
                class="category-card__img"
                loading="lazy"
                width="900"
                height="900"
              >
            {% else %}
              <div class="category-card__img category-card__img--placeholder"></div>
            {% endif %}
          </div>
          <div class="category-card__label">
            <span>{{ block.settings.label }}</span>
          </div>
        </a>
      {% endif %}
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Shop By Category",
  "settings": [
    { "type": "text", "id": "heading", "label": "Section Heading", "default": "Shop By Category" }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category Card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Category Image" },
        { "type": "text", "id": "label", "label": "Category Name", "default": "GLOVES" },
        { "type": "url", "id": "url", "label": "Link URL" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop By Category",
      "blocks": [
        { "type": "category", "settings": { "label": "GLOVES" } },
        { "type": "category", "settings": { "label": "PROTECTIVE GEAR" } },
        { "type": "category", "settings": { "label": "TRAINING EQUIPMENT" } }
      ]
    }
  ]
}
{% endschema %}
