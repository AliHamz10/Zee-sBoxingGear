{% liquid
  assign section_id = section.id
  assign total_blocks = section.blocks | where: 'type', 'category' | size
  assign demo_imgs = 'https://images.unsplash.com/photo-1545324418-cc1a3fa10c00?w=800&q=80,https://images.unsplash.com/photo-1571019613454-1cb2f99b2d8b?w=800&q=80,https://images.unsplash.com/photo-1549476464-37392f717541?w=800&q=80,https://images.unsplash.com/photo-1517438984742-1262db08379e?w=800&q=80' | split: ','
%}

<section class="sbc" id="sbc-{{ section_id }}">
  <div class="sbc__header">
    <h2 class="sbc__title">{{ section.settings.heading | default: 'SHOP BY CATEGORY' }}</h2>
  </div>

  <div class="sbc__viewport">
    <div class="sbc__track" id="sbc-track-{{ section_id }}">
      {% for block in section.blocks %}
        {% if block.type == 'category' %}
          {% liquid
            assign linked_collection = blank
            if block.settings.collection != blank
              assign linked_collection = collections[block.settings.collection]
            endif

            assign card_url = block.settings.url | default: '#'
            if linked_collection != blank
              assign card_url = linked_collection.url
            elsif block.settings.label != blank
              assign card_url = '/collections/' | append: block.settings.label | handleize
            endif

            assign card_label = block.settings.label
            if card_label == blank and linked_collection != blank
              assign card_label = linked_collection.title
            endif

            assign card_image = block.settings.image
            if card_image == blank and linked_collection != blank and linked_collection.image != blank
              assign card_image = linked_collection.image
            endif
          %}
          <a
            href="{{ card_url }}"
            class="sbc__card"
            data-sbc-card="{{ forloop.index0 }}"
            {{ block.shopify_attributes }}
          >
            <div class="sbc__card-img-wrap">
              {% if card_image != blank %}
                <img
                  src="{{ card_image | image_url: width: 800 }}"
                  alt="{{ card_label | escape }}"
                  class="sbc__card-img"
                  width="800"
                  height="1000"
                  loading="{% if forloop.index <= 3 %}eager{% else %}lazy{% endif %}"
                >
              {% else %}
                {% assign demo_src = demo_imgs[forloop.index0] %}
                <img
                  src="{{ demo_src }}"
                  alt="{{ card_label | escape }}"
                  class="sbc__card-img"
                  width="800"
                  height="1000"
                  loading="{% if forloop.index <= 3 %}eager{% else %}lazy{% endif %}"
                >
              {% endif %}
            </div>
            <div class="sbc__card-overlay">
              <span class="sbc__card-label">
                {{ card_label }}
                <svg class="sbc__card-arrow" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <path d="M4 10h12M11 5l5 5-5 5"/>
                </svg>
              </span>
            </div>
          </a>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <div class="sbc__footer">
    <div class="sbc__segments" id="sbc-segs-{{ section_id }}" role="tablist" aria-label="Category navigation">
      {% for block in section.blocks %}
        {% if block.type == 'category' %}
          <button
            class="sbc__seg{% if forloop.first %} is-active{% endif %}"
            data-sbc-seg="{{ forloop.index0 }}"
            type="button"
            aria-label="Go to slide {{ forloop.index }}"
          ></button>
        {% endif %}
      {% endfor %}
    </div>
    <span class="sbc__counter" id="sbc-counter-{{ section_id }}">
      <span class="sbc__counter-cur">1</span>
      <span class="sbc__counter-sep"> / </span>
      <span class="sbc__counter-total">{{ total_blocks }}</span>
    </span>
  </div>
</section>

<script>
(function() {
  var sid = {{ section_id | json }};
  var track = document.getElementById('sbc-track-' + sid);
  var segsContainer = document.getElementById('sbc-segs-' + sid);
  var counter = document.getElementById('sbc-counter-' + sid);
  if (!track) return;

  var cards = Array.from(track.querySelectorAll('.sbc__card'));
  var segs = segsContainer ? Array.from(segsContainer.querySelectorAll('.sbc__seg')) : [];
  var total = cards.length;
  var curIdx = 0;
  var isScrolling = false;

  function getVisibleIndex() {
    var trackLeft = track.getBoundingClientRect().left;
    var best = 0;
    var bestDist = Infinity;
    cards.forEach(function(c, i) {
      var dist = Math.abs(c.getBoundingClientRect().left - trackLeft);
      if (dist < bestDist) { bestDist = dist; best = i; }
    });
    return best;
  }

  function updateUI(idx) {
    curIdx = idx;
    segs.forEach(function(s, i) {
      s.classList.toggle('is-active', i === idx);
    });
    if (counter) {
      counter.querySelector('.sbc__counter-cur').textContent = idx + 1;
    }
  }

  function scrollToCard(idx) {
    if (!cards[idx]) return;
    isScrolling = true;
    track.scrollTo({ left: cards[idx].offsetLeft, behavior: 'smooth' });
    updateUI(idx);
    setTimeout(function() { isScrolling = false; }, 600);
  }

  // Segment clicks
  segs.forEach(function(seg, i) {
    seg.addEventListener('click', function() { scrollToCard(i); });
  });

  // Scroll listener
  var scrollTimer;
  track.addEventListener('scroll', function() {
    clearTimeout(scrollTimer);
    scrollTimer = setTimeout(function() {
      if (!isScrolling) updateUI(getVisibleIndex());
    }, 80);
  }, { passive: true });

  // Touch swipe
  var touchStartX = 0;
  track.addEventListener('touchstart', function(e) {
    touchStartX = e.touches[0].clientX;
  }, { passive: true });
  track.addEventListener('touchend', function(e) {
    var dx = touchStartX - e.changedTouches[0].clientX;
    if (Math.abs(dx) > 40) {
      scrollToCard(Math.min(Math.max(curIdx + (dx > 0 ? 1 : -1), 0), total - 1));
    }
  }, { passive: true });

  updateUI(0);
})();
</script>

{% schema %}
{
  "name": "Shop by Category",
  "settings": [
    { "type": "text", "id": "heading", "label": "Section Heading", "default": "SHOP BY CATEGORY" }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category Card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Card Image" },
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "text", "id": "label", "label": "Label" },
        { "type": "url", "id": "url", "label": "Custom URL" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop by Category",
      "blocks": [
        { "type": "category", "settings": { "label": "BOXING GLOVES" } },
        { "type": "category", "settings": { "label": "WOMENS CLOTHING" } },
        { "type": "category", "settings": { "label": "PUNCHING BAGS" } },
        { "type": "category", "settings": { "label": "PROTECTION" } }
      ]
    }
  ]
}
{% endschema %}
