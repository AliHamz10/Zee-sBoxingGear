<section class="hero">
  {% if section.settings.bg_image %}
    <img
      class="hero__bg"
      src="{{ section.settings.bg_image | image_url: width: 1800 }}"
      alt=""
      role="presentation"
      loading="eager"
      fetchpriority="high"
    >
  {% else %}
    <div class="hero__bg hero__bg--fallback"></div>
  {% endif %}
  <div class="hero__overlay"></div>

  <div class="hero__text-block">
    <div class="container">
      <p class="hero__eyebrow">{{ section.settings.eyebrow | default: "Premium Boxing Equipment" }}</p>
      <h1 class="hero__title">{{ section.settings.heading | default: "TRAIN LIKE A CHAMPION" }}</h1>
      {% if section.settings.subheading != blank %}
        <p class="hero__subtitle">{{ section.settings.subheading }}</p>
      {% endif %}
      <div class="hero__actions">
        {% if section.settings.btn_label != blank %}
          <a href="{{ section.settings.btn_url | default: routes.all_products_collection_url }}" class="btn btn--hero">
            {{ section.settings.btn_label }}
          </a>
        {% endif %}
        {% if section.settings.btn2_label != blank %}
          <a href="{{ section.settings.btn2_url | default: '#' }}" class="btn btn--hero btn--hero--ghost">
            {{ section.settings.btn2_label }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<!-- Trust Bar -->
<div class="trust-bar">
  <div class="trust-bar__grid container">
    <div class="trust-bar__item">
      <svg class="trust-bar__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 5v3h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
      </svg>
      <span>{{ section.settings.trust_1 | default: "Free Shipping Over $100" }}</span>
    </div>
    <div class="trust-bar__item">
      <svg class="trust-bar__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
      </svg>
      <span>{{ section.settings.trust_2 | default: "30-Day Easy Returns" }}</span>
    </div>
    <div class="trust-bar__item">
      <svg class="trust-bar__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
      </svg>
      <span>{{ section.settings.trust_3 | default: "Secure Checkout" }}</span>
    </div>
    <div class="trust-bar__item">
      <svg class="trust-bar__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
      </svg>
      <span>{{ section.settings.trust_4 | default: "Trusted by 10,000+ Fighters" }}</span>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "bg_image", "label": "Background Image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow Text", "default": "Premium Boxing Equipment" },
    { "type": "text", "id": "heading", "label": "Headline", "default": "TRAIN LIKE A CHAMPION" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Premium boxing gear for fighters at every level." },
    { "type": "text", "id": "btn_label", "label": "Primary Button Label", "default": "Shop Now" },
    { "type": "url",  "id": "btn_url",   "label": "Primary Button URL" },
    { "type": "text", "id": "btn2_label", "label": "Secondary Button Label" },
    { "type": "url",  "id": "btn2_url",  "label": "Secondary Button URL" },
    {
      "type": "header",
      "content": "Trust Bar"
    },
    { "type": "text", "id": "trust_1", "label": "Trust Item 1", "default": "Free Shipping Over $100" },
    { "type": "text", "id": "trust_2", "label": "Trust Item 2", "default": "30-Day Easy Returns" },
    { "type": "text", "id": "trust_3", "label": "Trust Item 3", "default": "Secure Checkout" },
    { "type": "text", "id": "trust_4", "label": "Trust Item 4", "default": "Trusted by 10,000+ Fighters" }
  ],
  "presets": [{ "name": "Hero Banner" }]
}
{% endschema %}
