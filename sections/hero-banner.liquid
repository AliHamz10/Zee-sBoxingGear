<section class="hero">
  {% if section.settings.bg_image %}
    <img
      class="hero__bg"
      src="{{ section.settings.bg_image | image_url: width: 2000 }}"
      alt=""
      role="presentation"
      loading="eager"
      fetchpriority="high"
    >
  {% else %}
    <div class="hero__bg hero__bg--fallback"></div>
  {% endif %}
  <div class="hero__overlay"></div>

  <div class="hero__content">
    <h1 class="hero__title">{{ section.settings.heading | default: "TRAIN LIKE A CHAMPION" }}</h1>
    {% if section.settings.subheading != blank %}
      <p class="hero__subtitle">{{ section.settings.subheading }}</p>
    {% endif %}
    {% if section.settings.btn_label != blank %}
      <a href="{{ section.settings.btn_url | default: routes.all_products_collection_url }}" class="hero__cta">
        {{ section.settings.btn_label }}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="9 18 15 12 9 6"/>
        </svg>
      </a>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "bg_image", "label": "Background Image" },
    { "type": "text", "id": "heading", "label": "Headline", "default": "TRAIN LIKE A CHAMPION" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Premium boxing gear for fighters at every level." },
    { "type": "text", "id": "btn_label", "label": "Button Label", "default": "SHOP NOW" },
    { "type": "url",  "id": "btn_url",   "label": "Button URL" }
  ],
  "presets": [{ "name": "Hero Banner" }]
}
{% endschema %}
