<footer class="site-footer" role="contentinfo">
  {% liquid
    assign brand_name = settings.brand_name | default: "Zee's Boxing Gear"
  %}

  <div class="footer-bottom-bar">
    <div class="container">
      <div class="footer-bottom-bar__inner">
        <div class="footer-legal">
          <div class="footer-legal__links">
            <a href="{{ routes.root_url }}">Home</a>
            <span>|</span>
            <a href="{{ routes.all_products_collection_url }}">Shop All</a>
            {% if shop.privacy_policy.url != blank %}
              <span>|</span>
              <a href="{{ shop.privacy_policy.url }}">{{ shop.privacy_policy.title }}</a>
            {% endif %}
          </div>
          <p class="footer-legal__copy">&copy; {{ 'now' | date: '%Y' }} {{ brand_name }}. All rights reserved.</p>
        </div>

        {% if shop.enabled_payment_types != blank %}
          <div class="footer-payments" aria-label="Accepted payment methods">
            {% for type in shop.enabled_payment_types %}
              <span class="payment-icon" title="{{ type | replace: '_', ' ' | capitalize }}">
                {{ type | payment_type_svg_tag }}
              </span>
            {% endfor %}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": []
}
{% endschema %}
