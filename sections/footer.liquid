<footer class="site-footer" role="contentinfo">
  {% liquid
    assign footer_menu = section.settings.footer_menu
    assign footer_menu_links = footer_menu.links
    assign brand_name = settings.brand_name | default: "Zee's Boxing Gear"
    assign has_policies = false
    assign has_social = false
    assign rendered_footer_links = 0

    if shop.privacy_policy.url != blank or shop.terms_of_service.url != blank or shop.shipping_policy.url != blank or shop.refund_policy.url != blank
      assign has_policies = true
    endif

    if settings.social_facebook != blank or settings.social_instagram != blank or settings.social_tiktok != blank or settings.social_youtube != blank
      assign has_social = true
    endif
  %}

  <div class="footer-newsletter">
    <div class="container">
      <div class="footer-newsletter__inner">
        <div class="footer-newsletter__copy">
          <p class="footer-newsletter__eyebrow">Newsletter</p>
          <p class="footer-newsletter__heading">Join the Fight Club</p>
          <p class="footer-newsletter__sub">Exclusive deals, product drops, and training updates sent straight to your inbox.</p>
        </div>
        <div class="footer-newsletter__form-wrap">
          {% form 'customer', id: 'footer-newsletter-form' %}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <div class="footer-newsletter__form">
              <input
                type="email"
                name="contact[email]"
                class="footer-newsletter__input"
                placeholder="Enter your email address"
                required
                autocomplete="email"
                aria-label="Email address for newsletter"
              >
              <button type="submit" class="footer-newsletter__btn">Subscribe</button>
            </div>
            {% if form.posted_successfully? %}
              <p class="footer-newsletter__success is-visible">You're in. Check your inbox for the next update.</p>
            {% endif %}
          {% endform %}
        </div>
      </div>
    </div>
  </div>

  <div class="footer-main">
    <div class="container">
      <div class="footer-grid footer-grid--compact">
        <div class="footer-col footer-col--menu">
          <h4 class="footer-col__title">{{ section.settings.footer_menu_title }}</h4>
          {% if footer_menu_links != blank %}
            <ul class="footer-links">
              {% for link in footer_menu_links %}
                {% assign is_policy_link = false %}
                {% if shop.refund_policy.url != blank and link.url == shop.refund_policy.url %}
                  {% assign is_policy_link = true %}
                {% endif %}
                {% if shop.shipping_policy.url != blank and link.url == shop.shipping_policy.url %}
                  {% assign is_policy_link = true %}
                {% endif %}
                {% if shop.privacy_policy.url != blank and link.url == shop.privacy_policy.url %}
                  {% assign is_policy_link = true %}
                {% endif %}
                {% if shop.terms_of_service.url != blank and link.url == shop.terms_of_service.url %}
                  {% assign is_policy_link = true %}
                {% endif %}

                {% unless is_policy_link %}
                  {% assign rendered_footer_links = rendered_footer_links | plus: 1 %}
                  <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                {% endunless %}
              {% endfor %}
            </ul>
            {% if rendered_footer_links == 0 %}
              <p class="footer-empty-state">Your footer menu only contains policy links right now, so they are shown in the Policies column instead.</p>
            {% endif %}
          {% else %}
            <p class="footer-empty-state">Assign a menu in the Footer section settings to display links here.</p>
          {% endif %}
        </div>

        <div class="footer-col footer-col--policies">
          <h4 class="footer-col__title">Policies</h4>
          {% if has_policies %}
            <ul class="footer-links">
              {% if shop.refund_policy.url != blank %}
                <li><a href="{{ shop.refund_policy.url }}">{{ shop.refund_policy.title }}</a></li>
              {% endif %}
              {% if shop.shipping_policy.url != blank %}
                <li><a href="{{ shop.shipping_policy.url }}">{{ shop.shipping_policy.title }}</a></li>
              {% endif %}
              {% if shop.privacy_policy.url != blank %}
                <li><a href="{{ shop.privacy_policy.url }}">{{ shop.privacy_policy.title }}</a></li>
              {% endif %}
              {% if shop.terms_of_service.url != blank %}
                <li><a href="{{ shop.terms_of_service.url }}">{{ shop.terms_of_service.title }}</a></li>
              {% endif %}
            </ul>
          {% else %}
            <p class="footer-empty-state">Add store policies in Shopify Settings to surface them here automatically.</p>
          {% endif %}
        </div>

        <div class="footer-col footer-col--contact">
          <h4 class="footer-col__title">Contact</h4>
          <div class="footer-contact">
            {% if section.settings.contact_hours != blank %}
              <div class="footer-contact__row">
                <span class="footer-contact__label">Hours</span>
                <p class="footer-contact__item">{{ section.settings.contact_hours }}</p>
              </div>
            {% endif %}
            {% if section.settings.contact_phone != blank %}
              <div class="footer-contact__row">
                <span class="footer-contact__label">Phone</span>
                <p class="footer-contact__item">
                  <a href="tel:{{ section.settings.contact_phone }}">{{ section.settings.contact_phone }}</a>
                </p>
              </div>
            {% endif %}
            {% if section.settings.contact_email != blank %}
              <div class="footer-contact__row">
                <span class="footer-contact__label">Email</span>
                <p class="footer-contact__item">
                  <a href="mailto:{{ section.settings.contact_email }}">{{ section.settings.contact_email }}</a>
                </p>
              </div>
            {% endif %}
          </div>

          <div class="footer-contact__actions">
            <a class="footer-inline-link" href="{{ routes.account_login_url }}">My Account</a>
            <a class="footer-inline-link" href="{{ routes.search_url }}">Search</a>
            <a class="footer-inline-link" href="{{ routes.all_products_collection_url }}">Shop All</a>
          </div>

          {% if has_social %}
            <div class="footer-social">
              {% if settings.social_facebook != blank %}
                <a href="{{ settings.social_facebook }}" class="footer-social__link" aria-label="Facebook" target="_blank" rel="noopener">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
                </a>
              {% endif %}
              {% if settings.social_instagram != blank %}
                <a href="{{ settings.social_instagram }}" class="footer-social__link" aria-label="Instagram" target="_blank" rel="noopener">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
                  </svg>
                </a>
              {% endif %}
              {% if settings.social_tiktok != blank %}
                <a href="{{ settings.social_tiktok }}" class="footer-social__link" aria-label="TikTok" target="_blank" rel="noopener">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.75a4.85 4.85 0 0 1-1.01-.06z"/></svg>
                </a>
              {% endif %}
              {% if settings.social_youtube != blank %}
                <a href="{{ settings.social_youtube }}" class="footer-social__link" aria-label="YouTube" target="_blank" rel="noopener">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/>
                  </svg>
                </a>
              {% endif %}
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>

  <div class="footer-bottom-bar">
    <div class="container">
      <div class="footer-bottom-bar__inner">
        <div class="footer-legal">
          <div class="footer-legal__links">
            <a href="{{ routes.root_url }}">Home</a>
            <span>|</span>
            <a href="{{ routes.all_products_collection_url }}">Shop All</a>
            {% if shop.privacy_policy.url != blank %}
              <span>|</span>
              <a href="{{ shop.privacy_policy.url }}">{{ shop.privacy_policy.title }}</a>
            {% endif %}
          </div>
          <p class="footer-legal__copy">&copy; {{ 'now' | date: '%Y' }} {{ brand_name }}. All rights reserved.</p>
        </div>

        {% if shop.enabled_payment_types != blank %}
          <div class="footer-payments" aria-label="Accepted payment methods">
            {% for type in shop.enabled_payment_types %}
              <span class="payment-icon" title="{{ type | replace: '_', ' ' | capitalize }}">
                {{ type | payment_type_svg_tag }}
              </span>
            {% endfor %}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "link_list",
      "id": "footer_menu",
      "label": "Footer Menu",
      "default": "footer"
    },
    {
      "type": "text",
      "id": "footer_menu_title",
      "label": "Footer Menu Title",
      "default": "Customer Service"
    },
    {
      "type": "text",
      "id": "contact_hours",
      "label": "Contact Hours",
      "default": "MON - SAT (9AM - 6PM)"
    },
    {
      "type": "text",
      "id": "contact_phone",
      "label": "Phone Number",
      "default": "+1 800 123 4567"
    },
    {
      "type": "text",
      "id": "contact_email",
      "label": "Email Address",
      "default": "support@zeesboxinggear.com"
    }
  ]
}
{% endschema %}
