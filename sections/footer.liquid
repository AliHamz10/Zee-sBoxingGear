<footer class="site-footer" role="contentinfo">

  <!-- ── Main Footer Grid ── -->
  <div class="footer-main">
    <div class="container">
      <div class="footer-grid">

        <!-- Col 1: Customer Service -->
        <div class="footer-col">
          <h4 class="footer-col__title">Customer Service</h4>
          <ul class="footer-links">
            <li><a href="/policies/refund-policy">Return &amp; Exchange</a></li>
            <li><a href="/policies/shipping-policy">Shipping &amp; Delivery</a></li>
            <li><a href="/pages/track-order">Track My Order</a></li>
            <li><a href="/pages/faq">FAQs</a></li>
            <li><a href="/pages/contact">Contact Us</a></li>
          </ul>
        </div>

        <!-- Col 2: About -->
        <div class="footer-col">
          <h4 class="footer-col__title">About Zee's</h4>
          <ul class="footer-links">
            <li><a href="/pages/about">Who We Are</a></li>
            <li><a href="/pages/careers">Jobs &amp; Careers</a></li>
            <li><a href="/pages/wholesale">Become Our Supplier</a></li>
            <li><a href="/pages/contact">Contact Us</a></li>
          </ul>
        </div>

        <!-- Col 3: Resources -->
        <div class="footer-col">
          <h4 class="footer-col__title">Resources</h4>
          <ul class="footer-links">
            <li><a href="/pages/reviews">Reviews</a></li>
            <li><a href="/pages/size-guide">Size Chart</a></li>
            <li><a href="/collections/gloves">Shop Gloves</a></li>
            <li><a href="/pages/faq">FAQs</a></li>
            <li><a href="/blogs/news">Blog</a></li>
          </ul>
        </div>

        <!-- Col 4: Contact -->
        <div class="footer-col">
          <h4 class="footer-col__title">Contact</h4>
          <div class="footer-contact">
            {% if section.settings.contact_hours != blank %}
              <p class="footer-contact__item">{{ section.settings.contact_hours }}</p>
            {% endif %}
            {% if section.settings.contact_phone != blank %}
              <p class="footer-contact__item">
                <a href="tel:{{ section.settings.contact_phone }}">{{ section.settings.contact_phone }}</a>
              </p>
            {% endif %}
            {% if section.settings.contact_email != blank %}
              <p class="footer-contact__item">
                <a href="mailto:{{ section.settings.contact_email }}">{{ section.settings.contact_email }}</a>
              </p>
            {% endif %}
          </div>

          <!-- Social Icons -->
          <div class="footer-social">
            {% if settings.social_facebook != blank %}
              <a href="{{ settings.social_facebook }}" class="footer-social__link" aria-label="Facebook" target="_blank" rel="noopener">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
              </a>
            {% endif %}
            {% if settings.social_instagram != blank %}
              <a href="{{ settings.social_instagram }}" class="footer-social__link" aria-label="Instagram" target="_blank" rel="noopener">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
                </svg>
              </a>
            {% endif %}
            {% if settings.social_tiktok != blank %}
              <a href="{{ settings.social_tiktok }}" class="footer-social__link" aria-label="TikTok" target="_blank" rel="noopener">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.75a4.85 4.85 0 0 1-1.01-.06z"/></svg>
              </a>
            {% endif %}
            {% if settings.social_youtube != blank %}
              <a href="{{ settings.social_youtube }}" class="footer-social__link" aria-label="YouTube" target="_blank" rel="noopener">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/>
                </svg>
              </a>
            {% endif %}
          </div>
        </div>

      </div>
    </div>
  </div>

  <!-- ── Footer Bottom Bar ── -->
  <div class="footer-bottom-bar">
    <div class="container">
      <div class="footer-bottom-bar__inner">

        <!-- Legal Links + Copyright -->
        <div class="footer-legal">
          <div class="footer-legal__links">
            <a href="/policies/privacy-policy">Privacy Policy</a>
            <span>|</span>
            <a href="/policies/terms-of-service">Terms &amp; Conditions</a>
            <span>|</span>
            <a href="/pages/sitemap">Site Map</a>
          </div>
          <p class="footer-legal__copy">
            &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All Rights Reserved.
          </p>
        </div>

        <!-- Payment Icons -->
        <div class="footer-payments" aria-label="Accepted payment methods">
          <!-- Visa -->
          <span class="payment-icon" title="Visa">
            <svg viewBox="0 0 38 24" width="38" height="24" role="img" aria-label="Visa">
              <rect width="38" height="24" rx="3" fill="#fff" stroke="#e0e0e0"/>
              <path d="M14.3 16.5h-2.1l1.3-8h2.1l-1.3 8zm8.7-7.8c-.4-.2-1.1-.4-1.9-.4-2.1 0-3.6 1.1-3.6 2.7 0 1.2 1.1 1.8 1.9 2.2.8.4 1.1.7 1.1 1.1 0 .6-.7.9-1.3.9-.9 0-1.3-.1-2-.4l-.3-.1-.3 1.8c.5.2 1.4.4 2.3.4 2.2 0 3.7-1.1 3.7-2.8 0-.9-.6-1.6-1.8-2.2-.8-.4-1.2-.6-1.2-1 0-.3.4-.7 1.2-.7.7 0 1.2.1 1.6.3l.2.1.3-1.9zm5.4-.2h-1.6c-.5 0-.9.1-1.1.7l-3 7.3h2.2l.4-1.2h2.7l.3 1.2h1.9l-1.8-8zm-2.5 5.2.9-2.4.5 2.4h-1.4zm-14.8-5.2-2 5.5-.2-1.1c-.4-1.3-1.6-2.7-2.9-3.4l1.9 7h2.2l3.2-8h-2.2z" fill="#1a1f71"/>
            </svg>
          </span>
          <!-- Mastercard -->
          <span class="payment-icon" title="Mastercard">
            <svg viewBox="0 0 38 24" width="38" height="24" role="img" aria-label="Mastercard">
              <rect width="38" height="24" rx="3" fill="#fff" stroke="#e0e0e0"/>
              <circle cx="15" cy="12" r="7" fill="#eb001b"/>
              <circle cx="23" cy="12" r="7" fill="#f79e1b"/>
              <path d="M19 6.8a7 7 0 0 1 0 10.4A7 7 0 0 1 19 6.8z" fill="#ff5f00"/>
            </svg>
          </span>
          <!-- PayPal -->
          <span class="payment-icon" title="PayPal">
            <svg viewBox="0 0 38 24" width="38" height="24" role="img" aria-label="PayPal">
              <rect width="38" height="24" rx="3" fill="#fff" stroke="#e0e0e0"/>
              <path d="M24.5 8.2c.2 1.5-.9 3.3-2.3 4a5 5 0 0 1-2.2.5h-.6c-.3 0-.5.2-.5.5l-.5 3.2c0 .2-.2.3-.4.3h-2c-.2 0-.3-.2-.3-.4l1.5-9.5c.1-.3.3-.5.6-.5h4c1.5 0 2.5.8 2.7 1.9z" fill="#003087"/>
              <path d="M26.5 9.8c.2 1.6-1 3.5-2.5 4.2a5.5 5.5 0 0 1-2.4.5h-.7c-.3 0-.5.2-.6.5l-.6 3.8c0 .2-.2.4-.4.4h-1.9c-.2 0-.4-.2-.3-.4l.3-2c.1-.3.3-.5.6-.5h.5c2.4 0 4.3-1.4 4.8-3.6.2-.8.1-1.5-.2-2.1.8.2 1.5.5 1.9 1.2a2 2 0 0 1 .5 1z" fill="#009cde"/>
            </svg>
          </span>
          <!-- Shop Pay -->
          <span class="payment-icon" title="Shop Pay">
            <svg viewBox="0 0 38 24" width="38" height="24" role="img" aria-label="Shop Pay">
              <rect width="38" height="24" rx="3" fill="#5a31f4"/>
              <path d="M10 15.5V9h2.7c1.5 0 2.4.8 2.4 2s-.9 2-2.4 2H11.3v2.5H10zm1.3-3.5h1.3c.7 0 1.1-.4 1.1-1s-.4-1-1.1-1h-1.3v2zm5.3 3.6c-.7 0-1.3-.3-1.6-.8v.7H14V9h1.3v2.3c.3-.5.9-.8 1.6-.8 1.3 0 2.1 1 2.1 2.3s-.8 2.3-2.1 2.3zm-.3-1c.6 0 1.1-.5 1.1-1.3s-.5-1.3-1.1-1.3-1.1.5-1.1 1.3.5 1.3 1.1 1.3zm5.4 2.5c-.9 2-1.7 2.4-2.8 2.4v-1c.6 0 1-.2 1.4-1l-2-5h1.3l1.3 3.5 1.2-3.5H28l-2.3 5.6z" fill="#fff"/>
            </svg>
          </span>
          <!-- Apple Pay placeholder -->
          <span class="payment-icon" title="Bank Transfer">
            <svg viewBox="0 0 38 24" width="38" height="24" role="img" aria-label="Bank Transfer">
              <rect width="38" height="24" rx="3" fill="#fff" stroke="#e0e0e0"/>
              <text x="5" y="16" font-size="7" font-family="Arial" fill="#555" font-weight="600">BANK</text>
            </svg>
          </span>
        </div>

      </div>
    </div>
  </div>

</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "contact_hours",
      "label": "Contact Hours",
      "default": "MON - SAT (9AM - 6PM)"
    },
    {
      "type": "text",
      "id": "contact_phone",
      "label": "Phone Number",
      "default": "+1 800 123 4567"
    },
    {
      "type": "text",
      "id": "contact_email",
      "label": "Email Address",
      "default": "support@zeesboxinggear.com"
    }
  ]
}
{% endschema %}
