<footer class="sf" role="contentinfo">
  {% liquid
    assign brand_name = settings.brand_name | default: "Zee's Boxing Gear"
    assign col1_links = section.settings.col1_menu.links
    assign col2_links = section.settings.col2_menu.links
    assign col3_links = section.settings.col3_menu.links
  %}

  <div class="sf__main">
    <div class="sf__inner">

      <!-- Left: 3 link columns -->
      <div class="sf__cols">

        <div class="sf__col">
          <h4 class="sf__col-title">{{ section.settings.col1_title | default: 'Customer Service' }}</h4>
          <ul class="sf__links">
            {% if col1_links != blank %}
              {% for link in col1_links %}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {% endfor %}
            {% else %}
              <li><a href="{{ routes.root_url }}">Track My Order</a></li>
              <li><a href="{{ routes.root_url }}">FAQs</a></li>
              <li><a href="{{ routes.root_url }}">Contact Us</a></li>
              <li><a href="{{ routes.root_url }}">Return and Refunds</a></li>
              <li><a href="{{ routes.root_url }}">Shipping &amp; Delivery</a></li>
            {% endif %}
          </ul>
        </div>

        <div class="sf__col">
          <h4 class="sf__col-title">{{ section.settings.col2_title | default: 'Policies' }}</h4>
          <ul class="sf__links">
            {% if col2_links != blank %}
              {% for link in col2_links %}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {% endfor %}
            {% else %}
              {% if shop.refund_policy.url != blank %}
                <li><a href="{{ shop.refund_policy.url }}">{{ shop.refund_policy.title }}</a></li>
              {% endif %}
              {% if shop.shipping_policy.url != blank %}
                <li><a href="{{ shop.shipping_policy.url }}">{{ shop.shipping_policy.title }}</a></li>
              {% endif %}
              {% if shop.privacy_policy.url != blank %}
                <li><a href="{{ shop.privacy_policy.url }}">{{ shop.privacy_policy.title }}</a></li>
              {% endif %}
              {% if shop.terms_of_service.url != blank %}
                <li><a href="{{ shop.terms_of_service.url }}">{{ shop.terms_of_service.title }}</a></li>
              {% endif %}
            {% endif %}
          </ul>
        </div>

        <div class="sf__col">
          <h4 class="sf__col-title">{{ section.settings.col3_title | default: "About Zee's" }}</h4>
          <ul class="sf__links">
            {% if col3_links != blank %}
              {% for link in col3_links %}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {% endfor %}
            {% else %}
              <li><a href="{{ routes.root_url }}">About Us</a></li>
              <li><a href="{{ routes.root_url }}">Blog</a></li>
              <li><a href="{{ routes.root_url }}">Careers</a></li>
              <li><a href="{{ routes.search_url }}">Search</a></li>
            {% endif %}
          </ul>
        </div>

      </div>

      <!-- Right: Newsletter -->
      <div class="sf__newsletter">
        <h4 class="sf__newsletter-title">{{ section.settings.newsletter_heading | default: 'SIGN UP FOR EXCLUSIVE NEWS & OFFERS' }}</h4>
        <p class="sf__newsletter-desc">{{ section.settings.newsletter_desc | default: 'By subscribing you agree to receive email marketing from us. You can unsubscribe at any time.' }}</p>
        {% form 'customer', id: 'sf-newsletter-form' %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="sf__newsletter-form">
            <input
              type="email"
              name="contact[email]"
              class="sf__newsletter-input"
              placeholder="Email address"
              required
              autocomplete="email"
              aria-label="Email address for newsletter"
            >
            <button type="submit" class="sf__newsletter-btn" aria-label="Subscribe">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </button>
          </div>
          {% if form.posted_successfully? %}
            <p class="sf__newsletter-success">You're in. Check your inbox for the next update.</p>
          {% endif %}
        {% endform %}
      </div>

    </div>
  </div>

  <!-- Divider -->
  <div class="sf__divider"></div>

  <!-- Bottom bar -->
  <div class="sf__bottom">
    <div class="sf__bottom-inner">

      <!-- Social icons — centered -->
      <div class="sf__social">
        {% if settings.social_facebook != blank %}
          <a href="{{ settings.social_facebook }}" class="sf__social-link" aria-label="Facebook" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
        {% else %}
          <a href="#" class="sf__social-link" aria-label="Facebook">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
        {% endif %}
        {% if settings.social_instagram != blank %}
          <a href="{{ settings.social_instagram }}" class="sf__social-link" aria-label="Instagram" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
        {% else %}
          <a href="#" class="sf__social-link" aria-label="Instagram">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
        {% endif %}
        {% if settings.social_youtube != blank %}
          <a href="{{ settings.social_youtube }}" class="sf__social-link" aria-label="YouTube" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/></svg>
          </a>
        {% else %}
          <a href="#" class="sf__social-link" aria-label="YouTube">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/></svg>
          </a>
        {% endif %}
        {% if settings.social_tiktok != blank %}
          <a href="{{ settings.social_tiktok }}" class="sf__social-link" aria-label="TikTok" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.34 6.34 0 0 0-6.13 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.75a4.85 4.85 0 0 1-1.01-.06z"/></svg>
          </a>
        {% else %}
          <a href="#" class="sf__social-link" aria-label="X / Twitter">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.736-8.834L2.25 2.25h6.844l4.264 5.639L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/></svg>
          </a>
        {% endif %}
        <a href="#" class="sf__social-link" aria-label="Pinterest">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
        </a>
      </div>

      <!-- Payment icons -->
      {% if shop.enabled_payment_types != blank %}
        <div class="sf__payments" aria-label="Accepted payment methods">
          {% for type in shop.enabled_payment_types %}
            {{ type | payment_type_svg_tag: class: 'sf__payment-icon' }}
          {% endfor %}
        </div>
      {% endif %}

    </div>

    <!-- Copyright -->
    <p class="sf__copy">&copy; {{ 'now' | date: '%Y' }} {{ brand_name | upcase }}</p>
  </div>

</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "text", "id": "col1_title", "label": "Column 1 Title", "default": "Customer Service" },
    { "type": "link_list", "id": "col1_menu", "label": "Column 1 Menu" },
    { "type": "text", "id": "col2_title", "label": "Column 2 Title", "default": "Policies" },
    { "type": "link_list", "id": "col2_menu", "label": "Column 2 Menu" },
    { "type": "text", "id": "col3_title", "label": "Column 3 Title", "default": "About Zee's" },
    { "type": "link_list", "id": "col3_menu", "label": "Column 3 Menu" },
    { "type": "text", "id": "newsletter_heading", "label": "Newsletter Heading", "default": "SIGN UP FOR EXCLUSIVE NEWS & OFFERS" },
    { "type": "textarea", "id": "newsletter_desc", "label": "Newsletter Description", "default": "By subscribing you agree to receive email marketing from us. You can unsubscribe at any time." }
  ]
}
{% endschema %}
