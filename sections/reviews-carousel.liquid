<section class="section reviews-section">
  <div class="container">
    <!-- Header -->
    <div class="reviews-header">
      <h2 class="reviews-header__title">{{ section.settings.heading | default: "Let customers speak for us" }}</h2>
      <div class="reviews-header__stars" aria-label="5 out of 5 stars">
        {% for i in (1..5) %}
          <svg width="22" height="22" viewBox="0 0 24 24" fill="#e63b2e"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        {% endfor %}
      </div>
      {% if section.settings.review_count != blank %}
        <p class="reviews-header__count">from {{ section.settings.review_count }} reviews</p>
      {% endif %}
    </div>

    <!-- Carousel Wrapper -->
    <div class="reviews-carousel-wrapper">
      <button class="reviews-carousel__btn reviews-carousel__btn--prev" id="reviews-prev" aria-label="Previous reviews">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>

      <div class="reviews-carousel" id="reviews-track">
        {% for block in section.blocks %}
          {% if block.type == 'review' %}
            <div class="review-card" {{ block.shopify_attributes }}>
              <div class="review-card__stars" aria-label="{{ block.settings.rating }} stars">
                {% for i in (1..5) %}
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="{% if i <= block.settings.rating %}#e63b2e{% else %}#ddd{% endif %}">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                {% endfor %}
              </div>
              {% if block.settings.title != blank %}
                <p class="review-card__title">{{ block.settings.title }}</p>
              {% endif %}
              <p class="review-card__text">{{ block.settings.text }}</p>
              {% if block.settings.product_image %}
                <div class="review-card__product">
                  <img
                    src="{{ block.settings.product_image | image_url: width: 120 }}"
                    alt="{{ block.settings.product_name }}"
                    width="60"
                    height="60"
                    loading="lazy"
                  >
                  {% if block.settings.product_name != blank %}
                    <span class="review-card__product-name">{{ block.settings.product_name }}</span>
                  {% endif %}
                </div>
              {% endif %}
              <div class="review-card__author">
                <span class="review-card__name">{{ block.settings.author }}</span>
                {% if block.settings.location != blank %}
                  <span class="review-card__location">{{ block.settings.location }}</span>
                {% endif %}
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>

      <button class="reviews-carousel__btn reviews-carousel__btn--next" id="reviews-next" aria-label="Next reviews">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Reviews Carousel",
  "settings": [
    { "type": "text", "id": "heading", "label": "Section Heading", "default": "Let customers speak for us" },
    { "type": "text", "id": "review_count", "label": "Review Count", "default": "250" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "range", "id": "rating", "min": 1, "max": 5, "step": 1, "label": "Rating", "default": 5 },
        { "type": "text", "id": "title", "label": "Review Title", "default": "Amazing quality gear!" },
        { "type": "textarea", "id": "text", "label": "Review Text", "default": "Best boxing gloves I've ever used. The quality is exceptional and the fit is perfect." },
        { "type": "image_picker", "id": "product_image", "label": "Product Image" },
        { "type": "text", "id": "product_name", "label": "Product Name" },
        { "type": "text", "id": "author", "label": "Reviewer Name", "default": "Marcus J." },
        { "type": "text", "id": "location", "label": "Location", "default": "London, UK" }
      ]
    }
  ],
  "presets": [
