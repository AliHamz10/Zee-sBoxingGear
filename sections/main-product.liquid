{% assign current_variant = product.selected_or_first_available_variant %}
{% assign is_sale = false %}
{% if current_variant.compare_at_price > current_variant.price %}
  {% assign is_sale = true %}
{% endif %}

<!-- Breadcrumb -->
<div class="container">
  <nav class="zbg-breadcrumb" aria-label="Breadcrumb">
    <a href="{{ routes.root_url }}">Home</a>
    <span>/</span>
    {% if collection %}
      <a href="{{ collection.url }}">{{ collection.title }}</a>
      <span>/</span>
    {% endif %}
    <span aria-current="page">{{ product.title }}</span>
  </nav>
</div>

<section class="pdp">
  <div class="container">
    <div class="pdp__inner">

      <!-- Gallery -->
      <div class="pdp__gallery">
        <div class="pdp__gallery-main" id="pdp-main">
          {% if product.featured_image %}
            <img
              id="pdp-main-img"
              class="pdp__main-img"
              src="{{ product.featured_image | image_url: width: 900 }}"
              alt="{{ product.featured_image.alt | escape | default: product.title }}"
              width="900"
              height="900"
              loading="eager"
            >
          {% else %}
            <div class="pdp__main-ph">
              {{ 'product-1' | placeholder_svg_tag: 'pdp__ph-svg' }}
            </div>
          {% endif %}
        </div>

        {% if product.images.size > 1 %}
          <div class="pdp__thumbs" id="pdp-thumbs" role="list">
            {% for image in product.images %}
              <button
                class="pdp__thumb{% if forloop.first %} is-active{% endif %}"
                data-src="{{ image | image_url: width: 900 }}"
                role="listitem"
                aria-label="View image {{ forloop.index }}"
              >
                <img
                  src="{{ image | image_url: width: 160 }}"
                  alt="{{ image.alt | escape | default: product.title }}"
                  width="80"
                  height="80"
                  loading="lazy"
                >
              </button>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <!-- Product Info -->
      <div class="pdp__info">
        {% if product.vendor != blank %}
          <p class="pdp__vendor">{{ product.vendor | upcase }}</p>
        {% endif %}

        <h1 class="pdp__title">{{ product.title }}</h1>

        <!-- Badges -->
        {% render 'badge', product: product %}

        <!-- Price -->
        <div class="pdp__price" id="pdp-price">
          {% if is_sale %}
            <span class="pdp__price-sale">{{ current_variant.price | money }}</span>
            <s class="pdp__price-compare">{{ current_variant.compare_at_price | money }}</s>
            {% assign savings = current_variant.compare_at_price | minus: current_variant.price %}
            {% assign pct = savings | times: 100 | divided_by: current_variant.compare_at_price %}
            <span class="pdp__price-save">Save {{ pct }}%</span>
          {% else %}
            <span class="pdp__price-reg" id="pdp-price-display">{{ current_variant.price | money }}</span>
          {% endif %}
        </div>

        <div id="pdp-form-wrap">
          {% form 'product', product, id: 'pdp-form', data-product-form: '' %}
            <input type="hidden" name="id" id="pdp-variant-id" value="{{ current_variant.id }}">

            <!-- Variants -->
            {% unless product.has_only_default_variant %}
              {% for option in product.options_with_values %}
                <div class="pdp__option">
                  <div class="pdp__option-label">
                    <span class="pdp__option-name">{{ option.name }}</span>
                    <span class="pdp__option-selected" id="pdp-opt-val-{{ forloop.index0 }}">{{ option.selected_value }}</span>
                  </div>
                  <div class="pdp__option-btns" data-option-index="{{ forloop.index0 }}">
                    {% for value in option.values %}
                      <button
                        type="button"
                        class="pdp__opt-btn{% if option.selected_value == value %} is-selected{% endif %}"
                        data-value="{{ value }}"
                        data-option="{{ forloop.parentloop.index0 }}"
                        {% unless product.available %}disabled{% endunless %}
                      >{{ value }}</button>
                    {% endfor %}
                  </div>
                </div>
              {% endfor %}
            {% endunless %}

            <!-- Quantity -->
            <div class="pdp__qty">
              <span class="pdp__option-name">Quantity</span>
              <div class="pdp__qty-ctrl">
                <button type="button" id="pdp-qty-minus" aria-label="Decrease quantity">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/></svg>
                </button>
                <input
                  type="number"
                  id="pdp-qty"
                  name="quantity"
                  value="1"
                  min="1"
                  aria-label="Quantity"
                >
                <button type="button" id="pdp-qty-plus" aria-label="Increase quantity">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                </button>
              </div>
            </div>

            <!-- Add to Cart -->
            <div class="pdp__actions">
              <button
                type="submit"
                class="pdp__atc-btn"
                id="pdp-atc"
                {% unless current_variant.available %}disabled{% endunless %}
              >
                {% if current_variant.available %}
                  ADD TO CART
                {% else %}
                  SOLD OUT
                {% endif %}
              </button>
            </div>

          {% endform %}
        </div>

        <!-- Description -->
        {% if product.description != blank %}
          <div class="pdp__desc">
            {{ product.description }}
          </div>
        {% else %}
          <div class="pdp__desc">
            <p>Premium quality boxing equipment built for fighters at every level. Engineered with durable materials to withstand intense training sessions and competitive bouts. Each piece of gear is designed to provide maximum protection, comfort, and performance.</p>
          </div>
        {% endif %}

        <!-- Meta row -->
        <div class="pdp__meta">
          {% if product.vendor != blank %}
            <div class="pdp__meta-item">
              <span class="pdp__meta-label">Brand</span>
              <span class="pdp__meta-val">{{ product.vendor }}</span>
            </div>
          {% endif %}
          {% if current_variant.sku != blank %}
            <div class="pdp__meta-item">
              <span class="pdp__meta-label">SKU</span>
              <span class="pdp__meta-val">{{ current_variant.sku }}</span>
            </div>
          {% endif %}
          <div class="pdp__meta-item">
            <span class="pdp__meta-label">Status</span>
            <span class="pdp__meta-val pdp__meta-val--{% if current_variant.available %}in{% else %}out{% endif %}">
              {% if current_variant.available %}In Stock{% else %}Out of Stock{% endif %}
            </span>
          </div>
        </div>

        <!-- Trust badges -->
        <div class="pdp__trust">
          <div class="pdp__trust-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            <span>Free shipping over $100</span>
          </div>
          <div class="pdp__trust-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            <span>30-day returns</span>
          </div>
          <div class="pdp__trust-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <span>Secure checkout</span>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<!-- Product JSON for JS -->
<script type="application/json" id="product-json">
  {{ product | json }}
</script>

<script>
(function () {
  // Thumbnail gallery
  var thumbs = document.querySelectorAll('.pdp__thumb');
  var mainImg = document.getElementById('pdp-main-img');
  thumbs.forEach(function (btn) {
    btn.addEventListener('click', function () {
      if (mainImg) mainImg.src = this.dataset.src;
      thumbs.forEach(function (t) { t.classList.remove('is-active'); });
      this.classList.add('is-active');
    });
  });

  // Qty controls
  var qtyInput = document.getElementById('pdp-qty');
  var minusBtn = document.getElementById('pdp-qty-minus');
  var plusBtn = document.getElementById('pdp-qty-plus');
  if (qtyInput && minusBtn && plusBtn) {
    minusBtn.addEventListener('click', function () {
      var v = parseInt(qtyInput.value, 10);
      if (v > 1) qtyInput.value = v - 1;
    });
    plusBtn.addEventListener('click', function () {
      qtyInput.value = parseInt(qtyInput.value, 10) + 1;
    });
  }

  // Variant selection
  var productData;
  var productJsonEl = document.getElementById('product-json');
  if (productJsonEl) {
    try { productData = JSON.parse(productJsonEl.textContent); } catch (e) {}
  }

  var optionBtnGroups = document.querySelectorAll('.pdp__option-btns');
  var selectedOptions = [];

  optionBtnGroups.forEach(function (group, gi) {
    var activeBtns = group.querySelectorAll('.pdp__opt-btn.is-selected');
    selectedOptions[gi] = activeBtns.length ? activeBtns[0].dataset.value : '';
    group.querySelectorAll('.pdp__opt-btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        group.querySelectorAll('.pdp__opt-btn').forEach(function (b) { b.classList.remove('is-selected'); });
        btn.classList.add('is-selected');
        selectedOptions[gi] = btn.dataset.value;
        var valSpan = document.getElementById('pdp-opt-val-' + gi);
        if (valSpan) valSpan.textContent = btn.dataset.value;
        updateVariant();
      });
    });
  });

  function updateVariant() {
    if (!productData || !productData.variants) return;
    var match = productData.variants.find(function (v) {
      return v.options.every(function (o, i) { return o === selectedOptions[i]; });
    });
    if (!match) return;
    var vidInput = document.getElementById('pdp-variant-id');
    var atcBtn = document.getElementById('pdp-atc');
    var priceEl = document.getElementById('pdp-price-display');
    if (vidInput) vidInput.value = match.id;
    if (atcBtn) {
      atcBtn.disabled = !match.available;
      atcBtn.textContent = match.available ? 'ADD TO CART' : 'SOLD OUT';
    }
    if (priceEl) priceEl.textContent = (match.price / 100).toLocaleString('en-US', { style: 'currency', currency: 'USD' });
  }
})();
</script>

{% schema %}
{
  "name": "Product",
  "settings": []
}
{% endschema %}
